{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01YTbxh2W1xaGYGXcRkpTBqt","type":"tool_result","content":"     1→#!/usr/bin/env bash\n     2→# spawn.sh — ClawClau v2: Spawn a Claude Code or Codex agent task\n     3→#\n     4→# Usage: spawn.sh [OPTIONS] <task-id> \"<prompt>\" [workdir]\n     5→#\n     6→# Options:\n     7→#   --agent <claude|codex>    agent type (default: claude)\n     8→#   --steerable               interactive mode — enables mid-task steering\n     9→#   --worktree                isolate in a dedicated git worktree\n    10→#   --branch <name>           worktree branch name (default: clawclau/<id>)\n    11→#   --timeout <sec>           timeout in seconds (default: 600)\n    12→#   --interval <sec>          progress report interval, 0=off (default: 0)\n    13→#   --max-retries <n>         max auto-retry count (default: 3)\n    14→#   --done-check <script>     path to Definition of Done check script\n    15→#   --model <name>            model to pass to the agent\n    16→\n    17→set -euo pipefail\n    18→SCRIPT_DIR=\"$(cd \"$(dirname \"${BASH_SOURCE[0]}\")\" && pwd)\"\n    19→source \"$SCRIPT_DIR/lib.sh\"\n    20→\n    21→# ── Defaults ───────────────────────────────────────────────────────────────\n    22→AGENT=\"claude\"\n    23→STEERABLE=false\n    24→USE_WORKTREE=false\n    25→BRANCH=\"\"\n    26→TIMEOUT=600\n    27→INTERVAL=0\n    28→MAX_RETRIES=3\n    29→DONE_CHECK=\"\"\n    30→MODEL=\"\"\n    31→PARENT_TASK_ID=\"\"\n    32→RETRY_COUNT=0\n    33→\n    34→# ── Parse flags ────────────────────────────────────────────────────────────\n    35→POSITIONAL=()\n    36→while [[ $# -gt 0 ]]; do\n    37→    case \"$1\" in\n    38→        --agent)        AGENT=\"$2\";         shift 2 ;;\n    39→        --steerable)    STEERABLE=true;     shift   ;;\n    40→        --worktree)     USE_WORKTREE=true;  shift   ;;\n    41→        --branch)       BRANCH=\"$2\";        shift 2 ;;\n    42→        --timeout)      TIMEOUT=\"$2\";       shift 2 ;;\n    43→        --interval)     INTERVAL=\"$2\";      shift 2 ;;\n    44→        --max-retries)  MAX_RETRIES=\"$2\";   shift 2 ;;\n    45→        --done-check)   DONE_CHECK=\"$2\";    shift 2 ;;\n    46→        --model)        MODEL=\"$2\";         shift 2 ;;\n    47→        # Internal: used by retry.sh\n    48→        --parent)       PARENT_TASK_ID=\"$2\"; shift 2 ;;\n    49→        --retry-count)  RETRY_COUNT=\"$2\";   shift 2 ;;\n    50→        --)             shift; break ;;\n    51→        -*) echo \"ERROR: Unknown option: $1\" >&2; exit 1 ;;\n    52→        *)  POSITIONAL+=(\"$1\"); shift ;;\n    53→    esac\n    54→done\n    55→set -- \"${POSITIONAL[@]+\"${POSITIONAL[@]}\"}\"\n    56→\n    57→# ── Positional args ────────────────────────────────────────────────────────\n    58→if [[ $# -lt 2 ]]; then\n    59→    echo \"Usage: spawn.sh [OPTIONS] <task-id> \\\"<prompt>\\\" [workdir]\" >&2\n    60→    exit 1\n    61→fi\n    62→\n    63→TASK_ID=\"$1\"\n    64→PROMPT=\"$2\"\n    65→WORKDIR=\"${3:-$(pwd)}\"\n    66→\n    67→# ── Validate ───────────────────────────────────────────────────────────────\n    68→cc_validate_task_id \"$TASK_ID\"\n    69→\n    70→if ! [[ \"$AGENT\" =~ ^(claude|codex)$ ]]; then\n    71→    echo \"ERROR: --agent must be 'claude' or 'codex'\" >&2; exit 1\n    72→fi\n    73→if ! [[ \"$TIMEOUT\" =~ ^[0-9]+$ ]] || [[ \"$TIMEOUT\" -lt 1 ]]; then\n    74→    echo \"ERROR: --timeout must be a positive integer\" >&2; exit 1\n    75→fi\n    76→if ! [[ \"$INTERVAL\" =~ ^[0-9]+$ ]]; then\n    77→    echo \"ERROR: --interval must be a non-negative integer\" >&2; exit 1\n    78→fi\n    79→if [[ -n \"$DONE_CHECK\" ]] && [[ ! -x \"$DONE_CHECK\" ]]; then\n    80→    echo \"ERROR: --done-check '$DONE_CHECK' not found or not executable\" >&2; exit 1\n    81→fi\n    82→\n    83→REQUIRED=(tmux jq)\n    84→[[ \"$AGENT\" == \"claude\" ]] && REQUIRED+=(claude)\n    85→[[ \"$AGENT\" == \"codex\" ]]  && REQUIRED+=(codex)\n    86→cc_require \"${REQUIRED[@]}\"\n    87→\n    88→# ── Init ───────────────────────────────────────────────────────────────────\n    89→cc_init\n    90→\n    91→LOG_EXT=\"json\"\n    92→[[ \"$AGENT\" == \"codex\" ]] && LOG_EXT=\"txt\"\n    93→$STEERABLE && LOG_EXT=\"txt\"\n    94→\n    95→LOG_FILE=\"$CC_LOG_DIR/${TASK_ID}.${LOG_EXT}\"\n    96→PROMPT_FILE=\"$CC_PROMPT_DIR/${TASK_ID}.txt\"\n    97→WRAPPER_FILE=\"$CC_PROMPT_DIR/${TASK_ID}-wrapper.sh\"\n    98→TMUX_SESSION=$(cc_tmux_session \"$TASK_ID\")\n    99→\n   100→# Check for task ID collision\n   101→if cc_task_exists \"$TASK_ID\"; then\n   102→    echo \"ERROR: task '$TASK_ID' already exists in registry. Use a different ID.\" >&2\n   103→    exit 1\n   104→fi\n   105→if tmux has-session -t \"$TMUX_SESSION\" 2>/dev/null; then\n   106→    echo \"ERROR: tmux session '$TMUX_SESSION' already exists\" >&2\n   107→    exit 1\n   108→fi\n   109→\n   110→# ── Git worktree (optional) ────────────────────────────────────────────────\n   111→AGENT_WORKDIR=\"$WORKDIR\"\n   112→WORKTREE_PATH=\"\"\n   113→BRANCH_NAME=\"\"\n   114→\n   115→if $USE_WORKTREE; then\n   116→    REPO_ROOT=$(git -C \"$WORKDIR\" rev-parse --show-toplevel 2>/dev/null) || {\n   117→        echo \"ERROR: --worktree requires workdir to be inside a git repository\" >&2; exit 1\n   118→    }\n   119→    BRANCH_NAME=\"${BRANCH:-clawclau/${TASK_ID}}\"\n   120→    WORKTREE_PATH=\"$CC_WORKTREE_DIR/${TASK_ID}\"\n   121→\n   122→    # Create new branch from current HEAD\n   123→    git -C \"$REPO_ROOT\" worktree add \"$WORKTREE_PATH\" -b \"$BRANCH_NAME\" 2>/dev/null || {\n   124→        echo \"ERROR: Failed to create worktree at '$WORKTREE_PATH' (branch may already exist)\" >&2\n   125→        exit 1\n   126→    }\n   127→    AGENT_WORKDIR=\"$WORKTREE_PATH\"\n   128→    echo \"Worktree: $WORKTREE_PATH (branch: $BRANCH_NAME)\"\n   129→fi\n   130→\n   131→# ── Write prompt file ──────────────────────────────────────────────────────\n   132→printf '%s' \"$PROMPT\" > \"$PROMPT_FILE\"\n   133→\n   134→# ── Build wrapper script ───────────────────────────────────────────────────\n   135→# The wrapper is called: bash -l wrapper.sh\n   136→# Using a wrapper avoids quote-escaping hell when passing the prompt through tmux.\n   137→\n   138→if [[ \"$AGENT\" == \"claude\" ]] && ! $STEERABLE; then\n   139→    # Claude print mode: stream-json, real-time logging, no steering\n   140→    cat > \"$WRAPPER_FILE\" << 'WRAPPER_EOF'\n   141→#!/usr/bin/env bash\n   142→# Args: $1=PROMPT_FILE $2=WORKDIR $3=LOG_FILE [$4=MODEL]\n   143→cd \"$2\"\n   144→MODEL_FLAG=()\n   145→[[ -n \"${4:-}\" ]] && MODEL_FLAG=(--model \"$4\")\n   146→exec claude -p --dangerously-skip-permissions \\\n   147→    --verbose --output-format stream-json --include-partial-messages \\\n   148→    \"${MODEL_FLAG[@]}\" \\\n   149→    \"$(cat \"$1\")\" 2>&1 | tee \"$3\"\n   150→WRAPPER_EOF\n   151→\n   152→elif [[ \"$AGENT\" == \"claude\" ]] && $STEERABLE; then\n   153→    # Claude steerable mode: interactive, logged via tmux pipe-pane\n   154→    cat > \"$WRAPPER_FILE\" << 'WRAPPER_EOF'\n   155→#!/usr/bin/env bash\n   156→# Args: $1=WORKDIR [$2=MODEL]\n   157→cd \"$1\"\n   158→MODEL_FLAG=()\n   159→[[ -n \"${2:-}\" ]] && MODEL_FLAG=(--model \"$2\")\n   160→exec claude --dangerously-skip-permissions \"${MODEL_FLAG[@]}\"\n   161→WRAPPER_EOF\n   162→\n   163→elif [[ \"$AGENT\" == \"codex\" ]]; then\n   164→    # Codex: full-auto mode, plain text log\n   165→    cat > \"$WRAPPER_FILE\" << 'WRAPPER_EOF'\n   166→#!/usr/bin/env bash\n   167→# Args: $1=PROMPT_FILE $2=WORKDIR $3=LOG_FILE [$4=MODEL]\n   168→cd \"$2\"\n   169→MODEL_FLAG=()\n   170→[[ -n \"${4:-}\" ]] && MODEL_FLAG=(-m \"$4\")\n   171→exec codex --approval-mode full-auto \"${MODEL_FLAG[@]}\" \"$(cat \"$1\")\" 2>&1 | tee \"$3\"\n   172→WRAPPER_EOF\n   173→fi\n   174→chmod +x \"$WRAPPER_FILE\"\n   175→\n   176→# ── Launch tmux session ────────────────────────────────────────────────────\n   177→if [[ \"$AGENT\" == \"claude\" ]] && $STEERABLE; then\n   178→    # Interactive: launch claude, then inject prompt via tmux paste-buffer\n   179→    tmux new-session -d -s \"$TMUX_SESSION\" -c \"$AGENT_WORKDIR\" \\\n   180→        \"bash -l $WRAPPER_FILE $AGENT_WORKDIR ${MODEL:-}\"\n   181→    sleep 0.5\n   182→    # Capture output via pipe-pane (works in interactive PTY mode)\n   183→    tmux pipe-pane -t \"$TMUX_SESSION\" \"cat >> $LOG_FILE\"\n   184→    sleep 0.3\n   185→    # Inject prompt using load-buffer + paste-buffer (handles special chars)\n   186→    tmux load-buffer -b \"prompt-$TASK_ID\" \"$PROMPT_FILE\"\n   187→    tmux paste-buffer -t \"$TMUX_SESSION\" -b \"prompt-$TASK_ID\" -p\n   188→    tmux send-keys -t \"$TMUX_SESSION\" \"\" Enter\n   189→else\n   190→    # Print / Codex mode: wrapper handles the log piping\n   191→    tmux new-session -d -s \"$TMUX_SESSION\" -c \"$AGENT_WORKDIR\" \\\n   192→        \"bash -l $WRAPPER_FILE $PROMPT_FILE $AGENT_WORKDIR $LOG_FILE ${MODEL:-}\"\n   193→fi\n   194→\n   195→# Verify session actually started\n   196→sleep 1\n   197→if ! tmux has-session -t \"$TMUX_SESSION\" 2>/dev/null; then\n   198→    echo \"ERROR: tmux session '$TMUX_SESSION' failed to start\" >&2\n   199→    if [[ -s \"$LOG_FILE\" ]]; then\n   200→        echo \"Last log output:\" >&2\n   201→        tail -5 \"$LOG_FILE\" >&2\n   202→    fi\n   203→    # Cleanup worktree if we created one\n   204→    if [[ -n \"$WORKTREE_PATH\" ]]; then\n   205→        git -C \"$WORKDIR\" worktree remove \"$WORKTREE_PATH\" --force 2>/dev/null || true\n   206→    fi\n   207→    exit 1\n   208→fi\n   209→\n   210→# ── Register task ──────────────────────────────────────────────────────────\n   211→NOW_MS=$(cc_now_ms)\n   212→TASK_JSON=$(jq -n \\\n   213→    --arg id          \"$TASK_ID\" \\\n   214→    --arg agent       \"$AGENT\" \\\n   215→    --arg mode        \"$(if $STEERABLE; then echo steerable; else echo print; fi)\" \\\n   216→    --arg session     \"$TMUX_SESSION\" \\\n   217→    --arg prompt      \"$PROMPT\" \\\n   218→    --arg workdir     \"$WORKDIR\" \\\n   219→    --arg agentDir    \"$AGENT_WORKDIR\" \\\n   220→    --arg log         \"$LOG_FILE\" \\\n   221→    --arg model       \"$MODEL\" \\\n   222→    --argjson startTs \"$NOW_MS\" \\\n   223→    --argjson timeout \"$TIMEOUT\" \\\n   224→    --argjson maxR    \"$MAX_RETRIES\" \\\n   225→    --argjson retryC  \"$RETRY_COUNT\" \\\n   226→    --arg parent      \"$PARENT_TASK_ID\" \\\n   227→    --arg worktree    \"$WORKTREE_PATH\" \\\n   228→    --arg branch      \"$BRANCH_NAME\" \\\n   229→    --arg doneCheck   \"$DONE_CHECK\" \\\n   230→    '{\n   231→        id:           $id,\n   232→        agent:        $agent,\n   233→        mode:         $mode,\n   234→        tmuxSession:  $session,\n   235→        prompt:       $prompt,\n   236→        workdir:      $workdir,\n   237→        agentWorkdir: $agentDir,\n   238→        log:          $log,\n   239→        model:        $model,\n   240→        startedAt:    $startTs,\n   241→        timeout:      $timeout,\n   242→        status:       \"running\",\n   243→        completedAt:  null,\n   244→        maxRetries:   $maxR,\n   245→        retryCount:   $retryC,\n   246→        parentTaskId: (if $parent != \"\" then $parent else null end),\n   247→        worktree:     (if $worktree != \"\" then $worktree else null end),\n   248→        branch:       (if $branch != \"\" then $branch else null end),\n   249→        doneCheck:    (if $doneCheck != \"\" then $doneCheck else null end),\n   250→        steerLog:     []\n   251→    }')\n   252→\n   253→cc_task_register \"$TASK_JSON\"\n   254→\n   255→# ── Background: completion detector ───────────────────────────────────────\n   256→(\n   257→    export PATH=\"/opt/homebrew/bin:/usr/local/bin:$HOME/.openclaw/bin:$PATH\"\n   258→    _TASK_ID=\"$TASK_ID\"\n   259→    _SESSION=\"$TMUX_SESSION\"\n   260→    _LOG=\"$LOG_FILE\"\n   261→    _REGISTRY=\"$CC_REGISTRY\"\n   262→    _DONE_CHECK=\"$DONE_CHECK\"\n   263→    _AGENT_DIR=\"$AGENT_WORKDIR\"\n   264→    _REPO_DIR=\"$WORKDIR\"\n   265→    _WORKTREE=\"$WORKTREE_PATH\"\n   266→\n   267→    while tmux has-session -t \"$_SESSION\" 2>/dev/null; do\n   268→        sleep 5\n   269→    done\n   270→    sleep 2   # allow log flush\n   271→\n   272→    NOW=$(date +%s000)\n   273→    STATUS=\"failed\"\n   274→\n   275→    if [[ -s \"$_LOG\" ]]; then\n   276→        STATUS=\"done\"\n   277→        # Run DoD check if provided\n   278→        if [[ -n \"$_DONE_CHECK\" ]] && [[ -x \"$_DONE_CHECK\" ]]; then\n   279→            if ! \"$_DONE_CHECK\" \"$_TASK_ID\" \"$_LOG\" \"$_AGENT_DIR\" 2>/dev/null; then\n   280→                STATUS=\"failed\"\n   281→            fi\n   282→        fi\n   283→    fi\n   284→\n   285→    jq --arg id \"$_TASK_ID\" --argjson ts \"$NOW\" --arg st \"$STATUS\" \\\n   286→        '(.[] | select(.id == $id)) |= . + {status: $st, completedAt: $ts}' \\\n   287→        \"$_REGISTRY\" > \"$_REGISTRY.tmp\" && mv \"$_REGISTRY.tmp\" \"$_REGISTRY\"\n   288→\n   289→    # Notify\n   290→    command -v openclaw >/dev/null 2>&1 && \\\n   291→        openclaw system event --text \"ClawClau: 任务 $_TASK_ID [$STATUS]\" --mode now 2>/dev/null || true\n   292→) &\n   293→disown\n   294→\n   295→# ── Background: progress reporter ─────────────────────────────────────────\n   296→if [[ \"$INTERVAL\" -gt 0 ]]; then\n   297→(\n   298→    set +e\n   299→    export PATH=\"/opt/homebrew/bin:/usr/local/bin:$HOME/.openclaw/bin:$PATH\"\n   300→    _TASK_ID=\"$TASK_ID\"\n   301→    _SESSION=\"$TMUX_SESSION\"\n   302→    _LOG=\"$LOG_FILE\"\n   303→    _INTERVAL=\"$INTERVAL\"\n   304→    _START_MS=$(date +%s000)\n   305→    _LAST_BYTES=0\n   306→\n   307→    while tmux has-session -t \"$_SESSION\" 2>/dev/null; do\n   308→        sleep \"$_INTERVAL\"\n   309→        [[ -f \"$_LOG\" ]] || continue\n   310→\n   311→        CURRENT_BYTES=$(wc -c < \"$_LOG\" 2>/dev/null | tr -d ' ' || echo 0)\n   312→        [[ \"$CURRENT_BYTES\" -le \"$_LAST_BYTES\" ]] && continue\n   313→        _LAST_BYTES=$CURRENT_BYTES\n   314→\n   315→        NOW_MS=$(date +%s000)\n   316→        ELAPSED=$(( (NOW_MS - _START_MS) / 1000 ))\n   317→        if [[ $ELAPSED -lt 60 ]]; then TIME_STR=\"${ELAPSED}秒\"; else TIME_STR=\"$((ELAPSED/60))分钟\"; fi\n   318→\n   319→        SNIPPET=$(cc_extract_text \"$_LOG\" 200)\n   320→        TEXT=\"[进度] 任务 $_TASK_ID: 已运行 $TIME_STR\"$'\\n'\"最新输出: ${SNIPPET}\"\n   321→\n   322→        command -v openclaw >/dev/null 2>&1 && \\\n   323→            openclaw system event --text \"$TEXT\" --mode now 2>/dev/null || true\n   324→    done\n   325→) &\n   326→disown\n   327→fi\n   328→\n   329→# ── Done ───────────────────────────────────────────────────────────────────\n   330→MODE_STR=\"print\"\n   331→$STEERABLE && MODE_STR=\"steerable\"\n   332→\n   333→echo \"Spawned: $TASK_ID\"\n   334→echo \"  Agent:    $AGENT ($MODE_STR)\"\n   335→echo \"  Session:  $TMUX_SESSION\"\n   336→echo \"  Workdir:  $AGENT_WORKDIR\"\n   337→[[ -n \"$WORKTREE_PATH\" ]] && echo \"  Worktree: $WORKTREE_PATH  branch: $BRANCH_NAME\"\n   338→echo \"  Log:      $LOG_FILE\"\n   339→echo \"  Timeout:  ${TIMEOUT}s  MaxRetries: $MAX_RETRIES\"\n   340→[[ -n \"$DONE_CHECK\" ]] && echo \"  DoneCheck: $DONE_CHECK\"\n   341→[[ \"$INTERVAL\" -gt 0 ]] && echo \"  Progress: every ${INTERVAL}s\"\n   342→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"493fb87d-5bdf-4877-a927-bd41d6d235b6","uuid":"30d55ed3-b7e3-4b67-85b2-43a00c6b6b64","timestamp":"2026-03-19T10:44:36.562Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/yjj/.openclaw/workspace/memory/clawclau2/spawn.sh","content":"#!/usr/bin/env bash\n# spawn.sh — ClawClau v2: Spawn a Claude Code or Codex agent task\n#\n# Usage: spawn.sh [OPTIONS] <task-id> \"<prompt>\" [workdir]\n#\n# Options:\n#   --agent <claude|codex>    agent type (default: claude)\n#   --steerable               interactive mode — enables mid-task steering\n#   --worktree                isolate in a dedicated git worktree\n#   --branch <name>           worktree branch name (default: clawclau/<id>)\n#   --timeout <sec>           timeout in seconds (default: 600)\n#   --interval <sec>          progress report interval, 0=off (default: 0)\n#   --max-retries <n>         max auto-retry count (default: 3)\n#   --done-check <script>     path to Definition of Done check script\n#   --model <name>            model to pass to the agent\n\nset -euo pipefail\nSCRIPT_DIR=\"$(cd \"$(dirname \"${BASH_SOURCE[0]}\")\" && pwd)\"\nsource \"$SCRIPT_DIR/lib.sh\"\n\n# ── Defaults ───────────────────────────────────────────────────────────────\nAGENT=\"claude\"\nSTEERABLE=false\nUSE_WORKTREE=false\nBRANCH=\"\"\nTIMEOUT=600\nINTERVAL=0\nMAX_RETRIES=3\nDONE_CHECK=\"\"\nMODEL=\"\"\nPARENT_TASK_ID=\"\"\nRETRY_COUNT=0\n\n# ── Parse flags ────────────────────────────────────────────────────────────\nPOSITIONAL=()\nwhile [[ $# -gt 0 ]]; do\n    case \"$1\" in\n        --agent)        AGENT=\"$2\";         shift 2 ;;\n        --steerable)    STEERABLE=true;     shift   ;;\n        --worktree)     USE_WORKTREE=true;  shift   ;;\n        --branch)       BRANCH=\"$2\";        shift 2 ;;\n        --timeout)      TIMEOUT=\"$2\";       shift 2 ;;\n        --interval)     INTERVAL=\"$2\";      shift 2 ;;\n        --max-retries)  MAX_RETRIES=\"$2\";   shift 2 ;;\n        --done-check)   DONE_CHECK=\"$2\";    shift 2 ;;\n        --model)        MODEL=\"$2\";         shift 2 ;;\n        # Internal: used by retry.sh\n        --parent)       PARENT_TASK_ID=\"$2\"; shift 2 ;;\n        --retry-count)  RETRY_COUNT=\"$2\";   shift 2 ;;\n        --)             shift; break ;;\n        -*) echo \"ERROR: Unknown option: $1\" >&2; exit 1 ;;\n        *)  POSITIONAL+=(\"$1\"); shift ;;\n    esac\ndone\nset -- \"${POSITIONAL[@]+\"${POSITIONAL[@]}\"}\"\n\n# ── Positional args ────────────────────────────────────────────────────────\nif [[ $# -lt 2 ]]; then\n    echo \"Usage: spawn.sh [OPTIONS] <task-id> \\\"<prompt>\\\" [workdir]\" >&2\n    exit 1\nfi\n\nTASK_ID=\"$1\"\nPROMPT=\"$2\"\nWORKDIR=\"${3:-$(pwd)}\"\n\n# ── Validate ───────────────────────────────────────────────────────────────\ncc_validate_task_id \"$TASK_ID\"\n\nif ! [[ \"$AGENT\" =~ ^(claude|codex)$ ]]; then\n    echo \"ERROR: --agent must be 'claude' or 'codex'\" >&2; exit 1\nfi\nif ! [[ \"$TIMEOUT\" =~ ^[0-9]+$ ]] || [[ \"$TIMEOUT\" -lt 1 ]]; then\n    echo \"ERROR: --timeout must be a positive integer\" >&2; exit 1\nfi\nif ! [[ \"$INTERVAL\" =~ ^[0-9]+$ ]]; then\n    echo \"ERROR: --interval must be a non-negative integer\" >&2; exit 1\nfi\nif [[ -n \"$DONE_CHECK\" ]] && [[ ! -x \"$DONE_CHECK\" ]]; then\n    echo \"ERROR: --done-check '$DONE_CHECK' not found or not executable\" >&2; exit 1\nfi\n\nREQUIRED=(tmux jq)\n[[ \"$AGENT\" == \"claude\" ]] && REQUIRED+=(claude)\n[[ \"$AGENT\" == \"codex\" ]]  && REQUIRED+=(codex)\ncc_require \"${REQUIRED[@]}\"\n\n# ── Init ───────────────────────────────────────────────────────────────────\ncc_init\n\nLOG_EXT=\"json\"\n[[ \"$AGENT\" == \"codex\" ]] && LOG_EXT=\"txt\"\n$STEERABLE && LOG_EXT=\"txt\"\n\nLOG_FILE=\"$CC_LOG_DIR/${TASK_ID}.${LOG_EXT}\"\nPROMPT_FILE=\"$CC_PROMPT_DIR/${TASK_ID}.txt\"\nWRAPPER_FILE=\"$CC_PROMPT_DIR/${TASK_ID}-wrapper.sh\"\nTMUX_SESSION=$(cc_tmux_session \"$TASK_ID\")\n\n# Check for task ID collision\nif cc_task_exists \"$TASK_ID\"; then\n    echo \"ERROR: task '$TASK_ID' already exists in registry. Use a different ID.\" >&2\n    exit 1\nfi\nif tmux has-session -t \"$TMUX_SESSION\" 2>/dev/null; then\n    echo \"ERROR: tmux session '$TMUX_SESSION' already exists\" >&2\n    exit 1\nfi\n\n# ── Git worktree (optional) ────────────────────────────────────────────────\nAGENT_WORKDIR=\"$WORKDIR\"\nWORKTREE_PATH=\"\"\nBRANCH_NAME=\"\"\n\nif $USE_WORKTREE; then\n    REPO_ROOT=$(git -C \"$WORKDIR\" rev-parse --show-toplevel 2>/dev/null) || {\n        echo \"ERROR: --worktree requires workdir to be inside a git repository\" >&2; exit 1\n    }\n    BRANCH_NAME=\"${BRANCH:-clawclau/${TASK_ID}}\"\n    WORKTREE_PATH=\"$CC_WORKTREE_DIR/${TASK_ID}\"\n\n    # Create new branch from current HEAD\n    git -C \"$REPO_ROOT\" worktree add \"$WORKTREE_PATH\" -b \"$BRANCH_NAME\" 2>/dev/null || {\n        echo \"ERROR: Failed to create worktree at '$WORKTREE_PATH' (branch may already exist)\" >&2\n        exit 1\n    }\n    AGENT_WORKDIR=\"$WORKTREE_PATH\"\n    echo \"Worktree: $WORKTREE_PATH (branch: $BRANCH_NAME)\"\nfi\n\n# ── Write prompt file ──────────────────────────────────────────────────────\nprintf '%s' \"$PROMPT\" > \"$PROMPT_FILE\"\n\n# ── Build wrapper script ───────────────────────────────────────────────────\n# The wrapper is called: bash -l wrapper.sh\n# Using a wrapper avoids quote-escaping hell when passing the prompt through tmux.\n\nif [[ \"$AGENT\" == \"claude\" ]] && ! $STEERABLE; then\n    # Claude print mode: stream-json, real-time logging, no steering\n    cat > \"$WRAPPER_FILE\" << 'WRAPPER_EOF'\n#!/usr/bin/env bash\n# Args: $1=PROMPT_FILE $2=WORKDIR $3=LOG_FILE [$4=MODEL]\ncd \"$2\"\nMODEL_FLAG=()\n[[ -n \"${4:-}\" ]] && MODEL_FLAG=(--model \"$4\")\nexec claude -p --dangerously-skip-permissions \\\n    --verbose --output-format stream-json --include-partial-messages \\\n    \"${MODEL_FLAG[@]}\" \\\n    \"$(cat \"$1\")\" 2>&1 | tee \"$3\"\nWRAPPER_EOF\n\nelif [[ \"$AGENT\" == \"claude\" ]] && $STEERABLE; then\n    # Claude steerable mode: interactive, logged via tmux pipe-pane\n    cat > \"$WRAPPER_FILE\" << 'WRAPPER_EOF'\n#!/usr/bin/env bash\n# Args: $1=WORKDIR [$2=MODEL]\ncd \"$1\"\nMODEL_FLAG=()\n[[ -n \"${2:-}\" ]] && MODEL_FLAG=(--model \"$2\")\nexec claude --dangerously-skip-permissions \"${MODEL_FLAG[@]}\"\nWRAPPER_EOF\n\nelif [[ \"$AGENT\" == \"codex\" ]]; then\n    # Codex: full-auto mode, plain text log\n    cat > \"$WRAPPER_FILE\" << 'WRAPPER_EOF'\n#!/usr/bin/env bash\n# Args: $1=PROMPT_FILE $2=WORKDIR $3=LOG_FILE [$4=MODEL]\ncd \"$2\"\nMODEL_FLAG=()\n[[ -n \"${4:-}\" ]] && MODEL_FLAG=(-m \"$4\")\nexec codex --approval-mode full-auto \"${MODEL_FLAG[@]}\" \"$(cat \"$1\")\" 2>&1 | tee \"$3\"\nWRAPPER_EOF\nfi\nchmod +x \"$WRAPPER_FILE\"\n\n# ── Launch tmux session ────────────────────────────────────────────────────\nif [[ \"$AGENT\" == \"claude\" ]] && $STEERABLE; then\n    # Interactive: launch claude, then inject prompt via tmux paste-buffer\n    tmux new-session -d -s \"$TMUX_SESSION\" -c \"$AGENT_WORKDIR\" \\\n        \"bash -l $WRAPPER_FILE $AGENT_WORKDIR ${MODEL:-}\"\n    sleep 0.5\n    # Capture output via pipe-pane (works in interactive PTY mode)\n    tmux pipe-pane -t \"$TMUX_SESSION\" \"cat >> $LOG_FILE\"\n    sleep 0.3\n    # Inject prompt using load-buffer + paste-buffer (handles special chars)\n    tmux load-buffer -b \"prompt-$TASK_ID\" \"$PROMPT_FILE\"\n    tmux paste-buffer -t \"$TMUX_SESSION\" -b \"prompt-$TASK_ID\" -p\n    tmux send-keys -t \"$TMUX_SESSION\" \"\" Enter\nelse\n    # Print / Codex mode: wrapper handles the log piping\n    tmux new-session -d -s \"$TMUX_SESSION\" -c \"$AGENT_WORKDIR\" \\\n        \"bash -l $WRAPPER_FILE $PROMPT_FILE $AGENT_WORKDIR $LOG_FILE ${MODEL:-}\"\nfi\n\n# Verify session actually started\nsleep 1\nif ! tmux has-session -t \"$TMUX_SESSION\" 2>/dev/null; then\n    echo \"ERROR: tmux session '$TMUX_SESSION' failed to start\" >&2\n    if [[ -s \"$LOG_FILE\" ]]; then\n        echo \"Last log output:\" >&2\n        tail -5 \"$LOG_FILE\" >&2\n    fi\n    # Cleanup worktree if we created one\n    if [[ -n \"$WORKTREE_PATH\" ]]; then\n        git -C \"$WORKDIR\" worktree remove \"$WORKTREE_PATH\" --force 2>/dev/null || true\n    fi\n    exit 1\nfi\n\n# ── Register task ──────────────────────────────────────────────────────────\nNOW_MS=$(cc_now_ms)\nTASK_JSON=$(jq -n \\\n    --arg id          \"$TASK_ID\" \\\n    --arg agent       \"$AGENT\" \\\n    --arg mode        \"$(if $STEERABLE; then echo steerable; else echo print; fi)\" \\\n    --arg session     \"$TMUX_SESSION\" \\\n    --arg prompt      \"$PROMPT\" \\\n    --arg workdir     \"$WORKDIR\" \\\n    --arg agentDir    \"$AGENT_WORKDIR\" \\\n    --arg log         \"$LOG_FILE\" \\\n    --arg model       \"$MODEL\" \\\n    --argjson startTs \"$NOW_MS\" \\\n    --argjson timeout \"$TIMEOUT\" \\\n    --argjson maxR    \"$MAX_RETRIES\" \\\n    --argjson retryC  \"$RETRY_COUNT\" \\\n    --arg parent      \"$PARENT_TASK_ID\" \\\n    --arg worktree    \"$WORKTREE_PATH\" \\\n    --arg branch      \"$BRANCH_NAME\" \\\n    --arg doneCheck   \"$DONE_CHECK\" \\\n    '{\n        id:           $id,\n        agent:        $agent,\n        mode:         $mode,\n        tmuxSession:  $session,\n        prompt:       $prompt,\n        workdir:      $workdir,\n        agentWorkdir: $agentDir,\n        log:          $log,\n        model:        $model,\n        startedAt:    $startTs,\n        timeout:      $timeout,\n        status:       \"running\",\n        completedAt:  null,\n        maxRetries:   $maxR,\n        retryCount:   $retryC,\n        parentTaskId: (if $parent != \"\" then $parent else null end),\n        worktree:     (if $worktree != \"\" then $worktree else null end),\n        branch:       (if $branch != \"\" then $branch else null end),\n        doneCheck:    (if $doneCheck != \"\" then $doneCheck else null end),\n        steerLog:     []\n    }')\n\ncc_task_register \"$TASK_JSON\"\n\n# ── Background: completion detector ───────────────────────────────────────\n(\n    export PATH=\"/opt/homebrew/bin:/usr/local/bin:$HOME/.openclaw/bin:$PATH\"\n    _TASK_ID=\"$TASK_ID\"\n    _SESSION=\"$TMUX_SESSION\"\n    _LOG=\"$LOG_FILE\"\n    _REGISTRY=\"$CC_REGISTRY\"\n    _DONE_CHECK=\"$DONE_CHECK\"\n    _AGENT_DIR=\"$AGENT_WORKDIR\"\n    _REPO_DIR=\"$WORKDIR\"\n    _WORKTREE=\"$WORKTREE_PATH\"\n\n    while tmux has-session -t \"$_SESSION\" 2>/dev/null; do\n        sleep 5\n    done\n    sleep 2   # allow log flush\n\n    NOW=$(date +%s000)\n    STATUS=\"failed\"\n\n    if [[ -s \"$_LOG\" ]]; then\n        STATUS=\"done\"\n        # Run DoD check if provided\n        if [[ -n \"$_DONE_CHECK\" ]] && [[ -x \"$_DONE_CHECK\" ]]; then\n            if ! \"$_DONE_CHECK\" \"$_TASK_ID\" \"$_LOG\" \"$_AGENT_DIR\" 2>/dev/null; then\n                STATUS=\"failed\"\n            fi\n        fi\n    fi\n\n    jq --arg id \"$_TASK_ID\" --argjson ts \"$NOW\" --arg st \"$STATUS\" \\\n        '(.[] | select(.id == $id)) |= . + {status: $st, completedAt: $ts}' \\\n        \"$_REGISTRY\" > \"$_REGISTRY.tmp\" && mv \"$_REGISTRY.tmp\" \"$_REGISTRY\"\n\n    # Notify\n    command -v openclaw >/dev/null 2>&1 && \\\n        openclaw system event --text \"ClawClau: 任务 $_TASK_ID [$STATUS]\" --mode now 2>/dev/null || true\n) &\ndisown\n\n# ── Background: progress reporter ─────────────────────────────────────────\nif [[ \"$INTERVAL\" -gt 0 ]]; then\n(\n    set +e\n    export PATH=\"/opt/homebrew/bin:/usr/local/bin:$HOME/.openclaw/bin:$PATH\"\n    _TASK_ID=\"$TASK_ID\"\n    _SESSION=\"$TMUX_SESSION\"\n    _LOG=\"$LOG_FILE\"\n    _INTERVAL=\"$INTERVAL\"\n    _START_MS=$(date +%s000)\n    _LAST_BYTES=0\n\n    while tmux has-session -t \"$_SESSION\" 2>/dev/null; do\n        sleep \"$_INTERVAL\"\n        [[ -f \"$_LOG\" ]] || continue\n\n        CURRENT_BYTES=$(wc -c < \"$_LOG\" 2>/dev/null | tr -d ' ' || echo 0)\n        [[ \"$CURRENT_BYTES\" -le \"$_LAST_BYTES\" ]] && continue\n        _LAST_BYTES=$CURRENT_BYTES\n\n        NOW_MS=$(date +%s000)\n        ELAPSED=$(( (NOW_MS - _START_MS) / 1000 ))\n        if [[ $ELAPSED -lt 60 ]]; then TIME_STR=\"${ELAPSED}秒\"; else TIME_STR=\"$((ELAPSED/60))分钟\"; fi\n\n        SNIPPET=$(cc_extract_text \"$_LOG\" 200)\n        TEXT=\"[进度] 任务 $_TASK_ID: 已运行 $TIME_STR\"$'\\n'\"最新输出: ${SNIPPET}\"\n\n        command -v openclaw >/dev/null 2>&1 && \\\n            openclaw system event --text \"$TEXT\" --mode now 2>/dev/null || true\n    done\n) &\ndisown\nfi\n\n# ── Done ───────────────────────────────────────────────────────────────────\nMODE_STR=\"print\"\n$STEERABLE && MODE_STR=\"steerable\"\n\necho \"Spawned: $TASK_ID\"\necho \"  Agent:    $AGENT ($MODE_STR)\"\necho \"  Session:  $TMUX_SESSION\"\necho \"  Workdir:  $AGENT_WORKDIR\"\n[[ -n \"$WORKTREE_PATH\" ]] && echo \"  Worktree: $WORKTREE_PATH  branch: $BRANCH_NAME\"\necho \"  Log:      $LOG_FILE\"\necho \"  Timeout:  ${TIMEOUT}s  MaxRetries: $MAX_RETRIES\"\n[[ -n \"$DONE_CHECK\" ]] && echo \"  DoneCheck: $DONE_CHECK\"\n[[ \"$INTERVAL\" -gt 0 ]] && echo \"  Progress: every ${INTERVAL}s\"\n","numLines":342,"startLine":1,"totalLines":342}}}
