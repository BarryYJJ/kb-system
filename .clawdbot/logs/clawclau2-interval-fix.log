{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0145qBqC3CuZ1D9k7Wh9SmXN","type":"tool_result","content":"     1→#!/usr/bin/env bash\n     2→# lib.sh — ClawClau v2 shared utilities\n     3→# Source this file: source \"$(dirname \"${BASH_SOURCE[0]}\")/lib.sh\"\n     4→\n     5→# ── Paths ──────────────────────────────────────────────────────────────────\n     6→CC_HOME=\"${CC_HOME:-$HOME/.openclaw/.clawclau2}\"\n     7→CC_REGISTRY=\"$CC_HOME/active-tasks.json\"\n     8→CC_LOG_DIR=\"$CC_HOME/logs\"\n     9→CC_PROMPT_DIR=\"$CC_HOME/prompts\"\n    10→CC_WORKTREE_DIR=\"$CC_HOME/worktrees\"\n    11→\n    12→# ── Init ───────────────────────────────────────────────────────────────────\n    13→cc_init() {\n    14→    mkdir -p \"$CC_LOG_DIR\" \"$CC_PROMPT_DIR\" \"$CC_WORKTREE_DIR\"\n    15→    [[ -f \"$CC_REGISTRY\" ]] || echo '[]' > \"$CC_REGISTRY\"\n    16→}\n    17→\n    18→# ── Dependency check ───────────────────────────────────────────────────────\n    19→cc_require() {\n    20→    for cmd in \"$@\"; do\n    21→        command -v \"$cmd\" >/dev/null 2>&1 || {\n    22→            echo \"ERROR: '$cmd' is required but not installed.\" >&2\n    23→            exit 1\n    24→        }\n    25→    done\n    26→}\n    27→\n    28→# ── Registry helpers ───────────────────────────────────────────────────────\n    29→\n    30→# Get a field value from a task in the registry\n    31→# Usage: cc_task_get <task-id> <field>\n    32→cc_task_get() {\n    33→    local id=\"$1\" field=\"$2\"\n    34→    jq -r --arg id \"$id\" --arg f \"$field\" \\\n    35→        '.[] | select(.id == $id) | .[$f] // \"\"' \\\n    36→        \"$CC_REGISTRY\" 2>/dev/null\n    37→}\n    38→\n    39→# Check if task exists in registry\n    40→# Usage: cc_task_exists <task-id>\n    41→cc_task_exists() {\n    42→    local id=\"$1\"\n    43→    local count\n    44→    count=$(jq --arg id \"$id\" '[.[] | select(.id == $id)] | length' \"$CC_REGISTRY\" 2>/dev/null || echo 0)\n    45→    [[ \"$count\" -gt 0 ]]\n    46→}\n    47→\n    48→# Add a new task to the registry\n    49→# Usage: cc_task_register <json-object>\n    50→cc_task_register() {\n    51→    local task_json=\"$1\"\n    52→    jq --argjson t \"$task_json\" '. += [$t]' \\\n    53→        \"$CC_REGISTRY\" > \"$CC_REGISTRY.tmp\" \\\n    54→        && mv \"$CC_REGISTRY.tmp\" \"$CC_REGISTRY\"\n    55→}\n    56→\n    57→# Update one or more fields on an existing task\n    58→# Usage: cc_task_update <task-id> <json-patch>\n    59→# Example: cc_task_update \"my-task\" '{\"status\":\"done\",\"completedAt\":1234}'\n    60→cc_task_update() {\n    61→    local id=\"$1\" patch=\"$2\"\n    62→    jq --arg id \"$id\" --argjson p \"$patch\" \\\n    63→        '(.[] | select(.id == $id)) |= . + $p' \\\n    64→        \"$CC_REGISTRY\" > \"$CC_REGISTRY.tmp\" \\\n    65→        && mv \"$CC_REGISTRY.tmp\" \"$CC_REGISTRY\"\n    66→}\n    67→\n    68→# Append to the steerLog array on a task\n    69→cc_task_steer_log() {\n    70→    local id=\"$1\" message=\"$2\"\n    71→    local ts\n    72→    ts=$(date +%s000)\n    73→    jq --arg id \"$id\" --arg msg \"$message\" --argjson ts \"$ts\" \\\n    74→        '(.[] | select(.id == $id)) |= . + {steerLog: ((.steerLog // []) + [{at: $ts, message: $msg}])}' \\\n    75→        \"$CC_REGISTRY\" > \"$CC_REGISTRY.tmp\" \\\n    76→        && mv \"$CC_REGISTRY.tmp\" \"$CC_REGISTRY\"\n    77→}\n    78→\n    79→# ── tmux helpers ───────────────────────────────────────────────────────────\n    80→\n    81→cc_tmux_session() {\n    82→    echo \"cc-${1}\"\n    83→}\n    84→\n    85→cc_tmux_alive() {\n    86→    local session\n    87→    session=$(cc_tmux_session \"$1\")\n    88→    tmux has-session -t \"$session\" 2>/dev/null\n    89→}\n    90→\n    91→# ── Log text extraction ────────────────────────────────────────────────────\n    92→\n    93→# Extract human-readable text from a log file\n    94→# Handles both stream-json (claude) and plain text (codex)\n    95→# Usage: cc_extract_text <log-file> [max-chars]\n    96→cc_extract_text() {\n    97→    local log_file=\"$1\"\n    98→    local max_chars=\"${2:-500}\"\n    99→\n   100→    [[ -f \"$log_file\" ]] || { echo \"\"; return; }\n   101→    [[ -s \"$log_file\" ]] || { echo \"\"; return; }\n   102→\n   103→    # Detect format: stream-json starts with '{'\n   104→    local first_char\n   105→    first_char=$(head -c1 \"$log_file\" 2>/dev/null)\n   106→\n   107→    if [[ \"$first_char\" == \"{\" ]]; then\n   108→        # Claude stream-json format\n   109→        # Priority: result > last assistant message > text_delta fragments\n   110→        local text\n   111→        text=$(jq -rs '\n   112→          ([ .[] | select(.type == \"result\") | (.result // \"\") ] | last // \"\") as $result |\n   113→          ([ .[] | select(.type == \"assistant\") |\n   114→             ((.message.content // []) | map(select(.type == \"text\") | .text) | join(\"\"))\n   115→          ] | last // \"\") as $assistant |\n   116→          ([ .[] |\n   117→             select(.type == \"stream_event\") |\n   118→             select(.event.type == \"content_block_delta\") |\n   119→             select(.event.delta.type == \"text_delta\") |\n   120→             .event.delta.text\n   121→          ] | join(\"\")) as $delta |\n   122→          if $result != \"\" then $result\n   123→          elif $assistant != \"\" then $assistant\n   124→          elif $delta != \"\" then $delta\n   125→          else \"\"\n   126→          end\n   127→        ' \"$log_file\" 2>/dev/null)\n   128→        # Return last N chars (bash 3.2 compat: ${v: -N} returns empty when N>len)\n   129→        if [[ \"${#text}\" -le \"$max_chars\" ]]; then\n   130→            echo \"$text\"\n   131→        else\n   132→            echo \"${text: -$max_chars}\"\n   133→        fi\n   134→    else\n   135→        # Plain text (codex or steerable claude with ANSI stripped)\n   136→        # Strip ANSI escape codes, return last N chars\n   137→        local text\n   138→        text=$(tail -200 \"$log_file\" 2>/dev/null \\\n   139→            | sed 's/\\x1b\\[[0-9;]*[mGKHF]//g' \\\n   140→            | tr -d '\\r' \\\n   141→            | grep -v '^$' \\\n   142→            | tail -c \"$max_chars\")\n   143→        echo \"$text\"\n   144→    fi\n   145→}\n   146→\n   147→# ── Notification ───────────────────────────────────────────────────────────\n   148→cc_notify() {\n   149→    local text=\"$1\"\n   150→    export PATH=\"/opt/homebrew/bin:/usr/local/bin:$HOME/.openclaw/bin:$PATH\"\n   151→    command -v openclaw >/dev/null 2>&1 \\\n   152→        && openclaw system event --text \"$text\" --mode now 2>/dev/null || true\n   153→}\n   154→\n   155→# ── Timestamp helpers ──────────────────────────────────────────────────────\n   156→cc_now_ms() { date +%s000; }\n   157→cc_elapsed_human() {\n   158→    local start_ms=\"$1\"\n   159→    local now_ms\n   160→    now_ms=$(cc_now_ms)\n   161→    local elapsed=$(( (now_ms - start_ms) / 1000 ))\n   162→    if [[ $elapsed -lt 60 ]]; then\n   163→        echo \"${elapsed}秒\"\n   164→    else\n   165→        echo \"$((elapsed / 60))分钟\"\n   166→    fi\n   167→}\n   168→\n   169→# ── Validation ─────────────────────────────────────────────────────────────\n   170→cc_validate_task_id() {\n   171→    local id=\"$1\"\n   172→    if ! [[ \"$id\" =~ ^[a-zA-Z0-9_-]+$ ]]; then\n   173→        echo \"ERROR: task-id must be alphanumeric (a-z, A-Z, 0-9, -, _). Got: '$id'\" >&2\n   174→        exit 1\n   175→    fi\n   176→}\n   177→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"1c334834-f53b-414b-8277-3e56e19dcfa5","uuid":"e5acf07f-fd92-4f26-9db0-34be4ea7dfeb","timestamp":"2026-03-19T09:27:07.865Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/yjj/.openclaw/workspace/memory/clawclau2/lib.sh","content":"#!/usr/bin/env bash\n# lib.sh — ClawClau v2 shared utilities\n# Source this file: source \"$(dirname \"${BASH_SOURCE[0]}\")/lib.sh\"\n\n# ── Paths ──────────────────────────────────────────────────────────────────\nCC_HOME=\"${CC_HOME:-$HOME/.openclaw/.clawclau2}\"\nCC_REGISTRY=\"$CC_HOME/active-tasks.json\"\nCC_LOG_DIR=\"$CC_HOME/logs\"\nCC_PROMPT_DIR=\"$CC_HOME/prompts\"\nCC_WORKTREE_DIR=\"$CC_HOME/worktrees\"\n\n# ── Init ───────────────────────────────────────────────────────────────────\ncc_init() {\n    mkdir -p \"$CC_LOG_DIR\" \"$CC_PROMPT_DIR\" \"$CC_WORKTREE_DIR\"\n    [[ -f \"$CC_REGISTRY\" ]] || echo '[]' > \"$CC_REGISTRY\"\n}\n\n# ── Dependency check ───────────────────────────────────────────────────────\ncc_require() {\n    for cmd in \"$@\"; do\n        command -v \"$cmd\" >/dev/null 2>&1 || {\n            echo \"ERROR: '$cmd' is required but not installed.\" >&2\n            exit 1\n        }\n    done\n}\n\n# ── Registry helpers ───────────────────────────────────────────────────────\n\n# Get a field value from a task in the registry\n# Usage: cc_task_get <task-id> <field>\ncc_task_get() {\n    local id=\"$1\" field=\"$2\"\n    jq -r --arg id \"$id\" --arg f \"$field\" \\\n        '.[] | select(.id == $id) | .[$f] // \"\"' \\\n        \"$CC_REGISTRY\" 2>/dev/null\n}\n\n# Check if task exists in registry\n# Usage: cc_task_exists <task-id>\ncc_task_exists() {\n    local id=\"$1\"\n    local count\n    count=$(jq --arg id \"$id\" '[.[] | select(.id == $id)] | length' \"$CC_REGISTRY\" 2>/dev/null || echo 0)\n    [[ \"$count\" -gt 0 ]]\n}\n\n# Add a new task to the registry\n# Usage: cc_task_register <json-object>\ncc_task_register() {\n    local task_json=\"$1\"\n    jq --argjson t \"$task_json\" '. += [$t]' \\\n        \"$CC_REGISTRY\" > \"$CC_REGISTRY.tmp\" \\\n        && mv \"$CC_REGISTRY.tmp\" \"$CC_REGISTRY\"\n}\n\n# Update one or more fields on an existing task\n# Usage: cc_task_update <task-id> <json-patch>\n# Example: cc_task_update \"my-task\" '{\"status\":\"done\",\"completedAt\":1234}'\ncc_task_update() {\n    local id=\"$1\" patch=\"$2\"\n    jq --arg id \"$id\" --argjson p \"$patch\" \\\n        '(.[] | select(.id == $id)) |= . + $p' \\\n        \"$CC_REGISTRY\" > \"$CC_REGISTRY.tmp\" \\\n        && mv \"$CC_REGISTRY.tmp\" \"$CC_REGISTRY\"\n}\n\n# Append to the steerLog array on a task\ncc_task_steer_log() {\n    local id=\"$1\" message=\"$2\"\n    local ts\n    ts=$(date +%s000)\n    jq --arg id \"$id\" --arg msg \"$message\" --argjson ts \"$ts\" \\\n        '(.[] | select(.id == $id)) |= . + {steerLog: ((.steerLog // []) + [{at: $ts, message: $msg}])}' \\\n        \"$CC_REGISTRY\" > \"$CC_REGISTRY.tmp\" \\\n        && mv \"$CC_REGISTRY.tmp\" \"$CC_REGISTRY\"\n}\n\n# ── tmux helpers ───────────────────────────────────────────────────────────\n\ncc_tmux_session() {\n    echo \"cc-${1}\"\n}\n\ncc_tmux_alive() {\n    local session\n    session=$(cc_tmux_session \"$1\")\n    tmux has-session -t \"$session\" 2>/dev/null\n}\n\n# ── Log text extraction ────────────────────────────────────────────────────\n\n# Extract human-readable text from a log file\n# Handles both stream-json (claude) and plain text (codex)\n# Usage: cc_extract_text <log-file> [max-chars]\ncc_extract_text() {\n    local log_file=\"$1\"\n    local max_chars=\"${2:-500}\"\n\n    [[ -f \"$log_file\" ]] || { echo \"\"; return; }\n    [[ -s \"$log_file\" ]] || { echo \"\"; return; }\n\n    # Detect format: stream-json starts with '{'\n    local first_char\n    first_char=$(head -c1 \"$log_file\" 2>/dev/null)\n\n    if [[ \"$first_char\" == \"{\" ]]; then\n        # Claude stream-json format\n        # Priority: result > last assistant message > text_delta fragments\n        local text\n        text=$(jq -rs '\n          ([ .[] | select(.type == \"result\") | (.result // \"\") ] | last // \"\") as $result |\n          ([ .[] | select(.type == \"assistant\") |\n             ((.message.content // []) | map(select(.type == \"text\") | .text) | join(\"\"))\n          ] | last // \"\") as $assistant |\n          ([ .[] |\n             select(.type == \"stream_event\") |\n             select(.event.type == \"content_block_delta\") |\n             select(.event.delta.type == \"text_delta\") |\n             .event.delta.text\n          ] | join(\"\")) as $delta |\n          if $result != \"\" then $result\n          elif $assistant != \"\" then $assistant\n          elif $delta != \"\" then $delta\n          else \"\"\n          end\n        ' \"$log_file\" 2>/dev/null)\n        # Return last N chars (bash 3.2 compat: ${v: -N} returns empty when N>len)\n        if [[ \"${#text}\" -le \"$max_chars\" ]]; then\n            echo \"$text\"\n        else\n            echo \"${text: -$max_chars}\"\n        fi\n    else\n        # Plain text (codex or steerable claude with ANSI stripped)\n        # Strip ANSI escape codes, return last N chars\n        local text\n        text=$(tail -200 \"$log_file\" 2>/dev/null \\\n            | sed 's/\\x1b\\[[0-9;]*[mGKHF]//g' \\\n            | tr -d '\\r' \\\n            | grep -v '^$' \\\n            | tail -c \"$max_chars\")\n        echo \"$text\"\n    fi\n}\n\n# ── Notification ───────────────────────────────────────────────────────────\ncc_notify() {\n    local text=\"$1\"\n    export PATH=\"/opt/homebrew/bin:/usr/local/bin:$HOME/.openclaw/bin:$PATH\"\n    command -v openclaw >/dev/null 2>&1 \\\n        && openclaw system event --text \"$text\" --mode now 2>/dev/null || true\n}\n\n# ── Timestamp helpers ──────────────────────────────────────────────────────\ncc_now_ms() { date +%s000; }\ncc_elapsed_human() {\n    local start_ms=\"$1\"\n    local now_ms\n    now_ms=$(cc_now_ms)\n    local elapsed=$(( (now_ms - start_ms) / 1000 ))\n    if [[ $elapsed -lt 60 ]]; then\n        echo \"${elapsed}秒\"\n    else\n        echo \"$((elapsed / 60))分钟\"\n    fi\n}\n\n# ── Validation ─────────────────────────────────────────────────────────────\ncc_validate_task_id() {\n    local id=\"$1\"\n    if ! [[ \"$id\" =~ ^[a-zA-Z0-9_-]+$ ]]; then\n        echo \"ERROR: task-id must be alphanumeric (a-z, A-Z, 0-9, -, _). Got: '$id'\" >&2\n        exit 1\n    fi\n}\n","numLines":177,"startLine":1,"totalLines":177}}}
