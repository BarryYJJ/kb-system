    j=5: arr[5]=11 ≤ 90 → i=5, swap arr[5]↔arr[5] → [64, 34, 25, 12, 22, 11, 90]
  Place pivot: swap arr[6]↔arr[6] → 90 at index 6
  Array: [64, 34, 25, 12, 22, 11, | 90 | ]
  pivot_idx=6 → recurse left(0,5), right(7,6 → skip)

--- quicksort(low=0, high=5) ---
  pivot = arr[5] = 11, i = -1

  Partition scan (j: 0 → 4):
    j=0: 64 > 11 → skip
    j=1: 34 > 11 → skip
    j=2: 25 > 11 → skip
    j=3: 12 > 11 → skip
    j=4: 22 > 11 → skip
  Place pivot: swap arr[0]↔arr[5]: 11 ↔ 64
  Array: [11, 34, 25, 12, 22, 64, 90]
  pivot_idx=0 → left(0,-1 → skip), right(1,5)

--- quicksort(low=1, high=5) ---
  pivot = arr[5] = 64, i = 0

  Partition scan (j: 1 → 4):
    j=1: 34 ≤ 64 → i=1, swap arr[1]↔arr[1] → [11, 34, 25, 12, 22, 64, 90]
    j=2: 25 ≤ 64 → i=2, swap arr[2]↔arr[2] → [11, 34, 25, 12, 22, 64, 90]
    j=3: 12 ≤ 64 → i=3, swap arr[3]↔arr[3] → [11, 34, 25, 12, 22, 64, 90]
    j=4: 22 ≤ 64 → i=4, swap arr[4]↔arr[4] → [11, 34, 25, 12, 22, 64, 90]
  Place pivot: swap arr[5]↔arr[5] → 64 at index 5
  Array: [11, | 34, 25, 12, 22 | 64 | 90]
  pivot_idx=5 → recurse left(1,4), right(6,5 → skip)

--- quicksort(low=1, high=4) ---
  pivot = arr[4] = 22, i = 0

  Partition scan (j: 1 → 3):
    j=1: 34 > 22 → skip
    j=2: 25 > 22 → skip
    j=3: 12 ≤ 22 → i=1, swap arr[1]↔arr[3]: 34 ↔ 12
    Array: [11, 12, 25, 34, 22, 64, 90]
  Place pivot: swap arr[2]↔arr[4]: 25 ↔ 22
  Array: [11, 12, 22, 34, 25, 64, 90]
  pivot_idx=2 → recurse left(1,1→base), right(3,4)

--- quicksort(low=3, high=4) ---
  pivot = arr[4] = 25, i = 2

  Partition scan (j: 3 → 3):
    j=3: 34 > 25 → skip
  Place pivot: swap arr[3]↔arr[4]: 34 ↔ 25
  Array: [11, 12, 22, 25, 34, 64, 90]
  pivot_idx=3 → left(3,2→skip), right(4,4→base)

Final: [11, 12, 22, 25, 34, 64, 90]  ← SORTED ✓
```

