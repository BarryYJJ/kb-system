{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01EdtnfM7wimdGKWHQFWAgVc","type":"tool_result","content":"     1→#!/bin/bash\n     2→# claude-spawn.sh — Spawn a Claude Code task in a tmux session\n     3→# Usage: claude-spawn.sh <task-id> \"<prompt>\" [workdir] [timeout-seconds] [--interval <seconds>]\n     4→\n     5→set -euo pipefail\n     6→\n     7→# --- Dependency check ---\n     8→for cmd in tmux jq; do\n     9→    command -v \"$cmd\" >/dev/null 2>&1 || { echo \"ERROR: '$cmd' is required but not installed.\"; exit 1; }\n    10→done\n    11→\n    12→# --- Configurable paths ---\n    13→CLAWCLAU_HOME=\"${CLAWCLAU_HOME:-$HOME/.openclaw/workspace/.clawdbot}\"\n    14→TASK_REGISTRY=\"$CLAWCLAU_HOME/active-tasks.json\"\n    15→LOG_DIR=\"$CLAWCLAU_HOME/logs\"\n    16→CLAWCLAU_SHELL=\"${CLAWCLAU_SHELL:-bash}\"\n    17→\n    18→# --- Pre-parse named flags (--interval) before positional args ---\n    19→PROGRESS_INTERVAL=0\n    20→REMAINING_ARGS=()\n    21→while [[ $# -gt 0 ]]; do\n    22→    case \"$1\" in\n    23→        --interval)\n    24→            if [[ -z \"${2:-}\" ]] || ! [[ \"${2}\" =~ ^[0-9]+$ ]]; then\n    25→                echo \"ERROR: --interval requires a positive integer (seconds). Got: '${2:-}'\"\n    26→                exit 1\n    27→            fi\n    28→            PROGRESS_INTERVAL=\"$2\"\n    29→            shift 2\n    30→            ;;\n    31→        *)\n    32→            REMAINING_ARGS+=(\"$1\")\n    33→            shift\n    34→            ;;\n    35→    esac\n    36→done\n    37→set -- \"${REMAINING_ARGS[@]+\"${REMAINING_ARGS[@]}\"}\"\n    38→\n    39→# --- Argument validation ---\n    40→if [ $# -lt 2 ]; then\n    41→    echo \"Usage: claude-spawn.sh <task-id> \\\"<prompt>\\\" [workdir] [timeout-seconds] [--interval <seconds>]\"\n    42→    exit 1\n    43→fi\n    44→\n    45→TASK_ID=\"$1\"\n    46→PROMPT=\"$2\"\n    47→WORKDIR=\"${3:-$(pwd)}\"\n    48→TIMEOUT=\"${4:-600}\"\n    49→\n    50→# --- Input sanitization (task-id: alphanumeric, dash, underscore only) ---\n    51→if ! echo \"$TASK_ID\" | grep -qE '^[a-zA-Z0-9_-]+$'; then\n    52→    echo \"ERROR: task-id must be alphanumeric (a-z, A-Z, 0-9, -, _). Got: '$TASK_ID'\"\n    53→    exit 1\n    54→fi\n    55→\n    56→TMUX_SESSION=\"claude-${TASK_ID}\"\n    57→\n    58→# --- Init directories and registry ---\n    59→mkdir -p \"$LOG_DIR\"\n    60→[ -f \"$TASK_REGISTRY\" ] || echo '[]' > \"$TASK_REGISTRY\"\n    61→\n    62→# --- Check for existing session ---\n    63→if tmux has-session -t \"$TMUX_SESSION\" 2>/dev/null; then\n    64→    echo \"ERROR: tmux session '$TMUX_SESSION' already exists\"\n    65→    exit 1\n    66→fi\n    67→\n    68→# --- Write prompt to temp file and generate wrapper script ---\n    69→# This avoids the nightmare of nesting quotes through tmux → shell → claude.\n    70→PROMPT_FILE=\"$CLAWCLAU_HOME/prompts/${TASK_ID}.txt\"\n    71→WRAPPER_FILE=\"$CLAWCLAU_HOME/prompts/${TASK_ID}.sh\"\n    72→TASK_LOG_FILE=\"$LOG_DIR/${TASK_ID}.log\"\n    73→mkdir -p \"$CLAWCLAU_HOME/prompts\" \"$LOG_DIR\"\n    74→printf '%s' \"$PROMPT\" > \"$PROMPT_FILE\"\n    75→\n    76→# The wrapper runs claude with --output-format stream-json, which makes claude\n    77→# explicitly flush each JSON event line to stdout immediately — even in pipe mode.\n    78→# This means tee receives data in real time, and the log file grows as the API\n    79→# streams tokens, not all at once when the task finishes.\n    80→#\n    81→# WHY NOT plain `tee`: claude -p in default text mode buffers ALL output until\n    82→# the API call completes, then writes everything at once. Log stays at 0 bytes.\n    83→#\n    84→# WHY NOT `script -q`: tested on macOS — script buffers its typescript file\n    85→# writes and only flushes when the child process exits. Same result as tee.\n    86→#\n    87→# WHY NOT `tmux pipe-pane`: the PTY gives claude line-buffering, but claude -p\n    88→# in text mode still accumulates the full API response before writing anything.\n    89→# The pipe-pane `cat` receives nothing until the API call finishes.\n    90→#\n    91→# WHY `--output-format stream-json`: claude explicitly flushes each JSON event\n    92→# to stdout immediately as it streams from the API. The stdio buffer never\n    93→# accumulates; every token is written to the log file within milliseconds.\n    94→# Tested: log grows from 0→1153 bytes at t=4s while the session is still alive.\n    95→cat > \"$WRAPPER_FILE\" << 'WRAPPER_EOF'\n    96→#!/bin/bash\n    97→# $1 = PROMPT_FILE, $2 = WORKDIR, $3 = LOG_FILE\n    98→cd \"$2\"\n    99→CLAWCLAU_PROMPT_FILE=\"$1\"\n   100→export CLAWCLAU_PROMPT_FILE\n   101→# --output-format stream-json: each API token/event is flushed to stdout\n   102→# immediately, making tee write to the log file in real time.\n   103→# --include-partial-messages: emit each text token as a separate event.\n   104→# --verbose: required when --output-format=stream-json is used with --print.\n   105→claude -p --dangerously-skip-permissions \\\n   106→    --verbose --output-format stream-json --include-partial-messages \\\n   107→    \"$(cat \"$CLAWCLAU_PROMPT_FILE\")\" 2>&1 | tee \"$3\"\n   108→WRAPPER_EOF\n   109→chmod +x \"$WRAPPER_FILE\"\n   110→\n   111→# --- Launch Claude Code in tmux ---\n   112→# Uses login shell to ensure PATH and env vars are loaded.\n   113→# --dangerously-skip-permissions bypasses interactive approval — see SECURITY.md.\n   114→tmux new-session -d -s \"$TMUX_SESSION\" -c \"$WORKDIR\" \\\n   115→    \"$CLAWCLAU_SHELL -l $WRAPPER_FILE $PROMPT_FILE $WORKDIR $TASK_LOG_FILE\"\n   116→\n   117→# Verify the session actually started\n   118→sleep 1\n   119→if ! tmux has-session -t \"$TMUX_SESSION\" 2>/dev/null; then\n   120→    # Session died immediately — check if log was created for diagnostics\n   121→    if [ -f \"$TASK_LOG_FILE\" ] && [ -s \"$TASK_LOG_FILE\" ]; then\n   122→        echo \"ERROR: tmux session '$TMUX_SESSION' started but exited immediately.\"\n   123→        echo \"  Last log output:\"\n   124→        tail -5 \"$TASK_LOG_FILE\"\n   125→    else\n   126→        echo \"ERROR: tmux session '$TMUX_SESSION' failed to start (no TTY or claude not found).\"\n   127→    fi\n   128→    exit 1\n   129→fi\n   130→\n   131→# --- Register task ---\n   132→TIMESTAMP=$(date +%s000)\n   133→jq --arg id \"$TASK_ID\" \\\n   134→   --arg session \"$TMUX_SESSION\" \\\n   135→   --arg prompt \"$PROMPT\" \\\n   136→   --arg workdir \"$WORKDIR\" \\\n   137→   --arg log \"$LOG_DIR/${TASK_ID}.log\" \\\n   138→   --arg ts \"$TIMESTAMP\" \\\n   139→   --arg timeout \"$TIMEOUT\" \\\n   140→   '. += [{\"id\": $id, \"tmuxSession\": $session, \"prompt\": $prompt, \"workdir\": $workdir, \"log\": $log, \"startedAt\": ($ts|tonumber), \"status\": \"running\", \"timeout\": ($timeout|tonumber)}]' \\\n   141→   \"$TASK_REGISTRY\" > \"$TASK_REGISTRY.tmp\" && mv \"$TASK_REGISTRY.tmp\" \"$TASK_REGISTRY\"\n   142→\n   143→# --- Background monitor: auto-notify when task finishes ---\n   144→(\n   145→    # Source profile so openclaw is in PATH\n   146→    export PATH=\"/opt/homebrew/bin:/usr/local/bin:$HOME/.openclaw/bin:$PATH\"\n   147→    while tmux has-session -t \"$TMUX_SESSION\" 2>/dev/null; do\n   148→        sleep 10\n   149→    done\n   150→    # Session ended — wait for log flush\n   151→    sleep 2\n   152→    NOW_TS=$(date +%s000)\n   153→    if [ -s \"$TASK_LOG_FILE\" ]; then\n   154→        STATUS=\"done\"\n   155→        EVENT_TEXT=\"Done: 任务 $TASK_ID 已完成\"\n   156→    else\n   157→        STATUS=\"failed\"\n   158→        EVENT_TEXT=\"Failed: 任务 $TASK_ID 失败（空日志）\"\n   159→    fi\n   160→    # Update registry\n   161→    jq --arg id \"$TASK_ID\" --arg ts \"$NOW_TS\" --arg status \"$STATUS\" \\\n   162→        '(.[] | select(.id == $id)) |= . + {status: $status, completedAt: ($ts | tonumber)}' \\\n   163→        \"$TASK_REGISTRY\" > \"$TASK_REGISTRY.tmp\" && mv \"$TASK_REGISTRY.tmp\" \"$TASK_REGISTRY\"\n   164→    # Notify via openclaw\n   165→    openc