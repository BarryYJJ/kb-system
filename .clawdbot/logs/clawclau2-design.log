xt\") | .text) | join(\"\"))\n   205→          ] | last // \"\") as $assistant |\n   206→          ([ .[] |\n   207→             select(.type == \"stream_event\") |\n   208→             select(.event.type == \"content_block_delta\") |\n   209→             select(.event.delta.type == \"text_delta\") |\n   210→             .event.delta.text\n   211→          ] | join(\"\")) as $delta |\n   212→          if $result != \"\" then $result\n   213→          elif $assistant != \"\" then $assistant\n   214→          elif $delta != \"\" then $delta\n   215→          else \"\"\n   216→          end\n   217→        ' 2>/dev/null)\n   218→        # Truncate to last 200 chars to keep notifications readable\n   219→        LOG_SNIPPET=\"${_RAW_TEXT: -200}\"\n   220→\n   221→        _EVENT_TEXT=\"[进度] 任务 $TASK_ID: 已运行 $TIME_STR\"$'\\n'\"最新输出：${LOG_SNIPPET}\"\n   222→        openclaw system event \\\n   223→            --text \"$_EVENT_TEXT\" \\\n   224→            --mode now 2>/dev/null || true\n   225→    done\n   226→) &\n   227→disown\n   228→fi\n   229→\n   230→echo \"OK: spawned '$TASK_ID' in tmux session '$TMUX_SESSION'\"\n   231→echo \"  Prompt: $PROMPT\"\n   232→echo \"  Workdir: $WORKDIR\"\n   233→echo \"  Log: $LOG_DIR/${TASK_ID}.log\"\n   234→echo \"  Timeout: ${TIMEOUT}s\"\n   235→echo \"  Monitor: background (auto-notify on completion)\"\n   236→if [ \"$PROGRESS_INTERVAL\" -gt 0 ]; then\n   237→    echo \"  Progress: every ${PROGRESS_INTERVAL}s (--interval)\"\n   238→fi\n   239→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"7dec3f60-2165-4422-8434-2be6f8f9065a","uuid":"84b98d42-abe8-4843-8748-41c80aaf6a99","timestamp":"2026-03-19T08:45:50.169Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/yjj/.openclaw/workspace/skills/clawclau/scripts/claude-spawn.sh","content":"#!/bin/bash\n# claude-spawn.sh — Spawn a Claude Code task in a tmux session\n# Usage: claude-spawn.sh <task-id> \"<prompt>\" [workdir] [timeout-seconds] [--interval <seconds>]\n\nset -euo pipefail\n\n# --- Dependency check ---\nfor cmd in tmux jq; do\n    command -v \"$cmd\" >/dev/null 2>&1 || { echo \"ERROR: '$cmd' is required but not installed.\"; exit 1; }\ndone\n\n# --- Configurable paths ---\nCLAWCLAU_HOME=\"${CLAWCLAU_HOME:-$HOME/.openclaw/workspace/.clawdbot}\"\nTASK_REGISTRY=\"$CLAWCLAU_HOME/active-tasks.json\"\nLOG_DIR=\"$CLAWCLAU_HOME/logs\"\nCLAWCLAU_SHELL=\"${CLAWCLAU_SHELL:-bash}\"\n\n# --- Pre-parse named flags (--interval) before positional args ---\nPROGRESS_INTERVAL=0\nREMAINING_ARGS=()\nwhile [[ $# -gt 0 ]]; do\n    case \"$1\" in\n        --interval)\n            if [[ -z \"${2:-}\" ]] || ! [[ \"${2}\" =~ ^[0-9]+$ ]]; then\n                echo \"ERROR: --interval requires a positive integer (seconds). Got: '${2:-}'\"\n                exit 1\n            fi\n            PROGRESS_INTERVAL=\"$2\"\n            shift 2\n            ;;\n        *)\n            REMAINING_ARGS+=(\"$1\")\n            shift\n            ;;\n    esac\ndone\nset -- \"${REMAINING_ARGS[@]+\"${REMAINING_ARGS[@]}\"}\"\n\n# --- Argument validation ---\nif [ $# -lt 2 ]; then\n    echo \"Usage: claude-spawn.sh <task-id> \\\"<prompt>\\\" [workdir] [timeout-seconds] [--interval <seconds>]\"\n    exit 1\nfi\n\nTASK_ID=\"$1\"\nPROMPT=\"$2\"\nWORKDIR=\"${3:-$(pwd)}\"\nTIMEOUT=\"${4:-600}\"\n\n# --- Input sanitization (task-id: alphanumeric, dash, underscore only) ---\nif ! echo \"$TASK_ID\" | grep -qE '^[a-zA-Z0-9_-]+$'; then\n    echo \"ERROR: task-id must be alphanumeric (a-z, A-Z, 0-9, -, _). Got: '$TASK_ID'\"\n    exit 1\nfi\n\nTMUX_SESSION=\"claude-${TASK_ID}\"\n\n# --- Init directories and registry ---\nmkdir -p \"$LOG_DIR\"\n[ -f \"$TASK_REGISTRY\" ] || echo '[]' > \"$TASK_REGISTRY\"\n\n# --- Check for existing session ---\nif tmux has-session -t \"$TMUX_SESSION\" 2>/dev/null; then\n    echo \"ERROR: tmux session '$TMUX_SESSION' already exists\"\n    exit 1\nfi\n\n# --- Write prompt to temp file and generate wrapper script ---\n# This avoids the nightmare of nesting quotes through tmux → shell → claude.\nPROMPT_FILE=\"$CLAWCLAU_HOME/prompts/${TASK_ID}.txt\"\nWRAPPER_FILE=\"$CLAWCLAU_HOME/prompts/${TASK_ID}.sh\"\nTASK_LOG_FILE=\"$LOG_DIR/${TASK_ID}.log\"\nmkdir -p \"$CLAWCLAU_HOME/prompts\" \"$LOG_DIR\"\nprintf '%s' \"$PROMPT\" > \"$PROMPT_FILE\"\n\n# The wrapper runs claude with --output-format stream-json, which makes claude\n# explicitly flush each JSON event line to stdout immediately — even in pipe mode.\n# This means tee receives data in real time, and the log file grows as the API\n# streams tokens, not all at once when the task finishes.\n#\n# WHY NOT plain `tee`: claude -p in default text mode buffers ALL output until\n# the API call completes, then writes everything at once. Log stays at 0 bytes.\n#\n# WHY NOT `script -q`: tested on macOS — script buffers its typescript file\n# writes and only flushes when the child process exits. Same result as tee.\n#\n# WHY NOT `tmux pipe-pane`: the PTY gives claude line-buffering, but claude -p\n# in text mode still accumulates the full API response before writing anything.\n# The pipe-pane `cat` receives nothing until the API call finishes.\n#\n# WHY `--output-format stream-json`: claude explicitly flushes each JSON event\n# to stdout immediately as it streams from the API. The stdio buffer never\n# accumulates; every token is written to the log file within milliseconds.\n# Tested: log grows from 0→1153 bytes at t=4s while the session is still alive.\ncat > \"$WRAPPER_FILE\" << 'WRAPPER_EOF'\n#!/bin/bash\n# $1 = PROMPT_FILE, $2 = WORKDIR, $3 = LOG_FILE\ncd \"$2\"\nCLAWCLAU_PROMPT_FILE=\"$1\"\nexport CLAWCLAU_PROMPT_FILE\n# --output-format stream-json: each API token/event is flushed to stdout\n# immediately, making tee write to the log file in real time.\n# --include-partial-messages: emit each text token as a separate event.\n# --verbose: required when --output-format=stream-json is used with --print.\nclaude -p --dangerously-skip-permissions \\\n    --verbose --output-format stream-json --include-partial-messages \\\n    \"$(cat \"$CLAWCLAU_PROMPT_FILE\")\" 2>&1 | tee \"$3\"\nWRAPPER_EOF\nchmod +x \"$WRAPPER_FILE\"\n\n# --- Launch Claude Code in tmux ---\n# Uses login shell to ensure PATH and env vars are loaded.\n# --dangerously-skip-permissions bypasses interactive approval — see SECURITY.md.\ntmux new-session -d -s \"$TMUX_SESSION\" -c \"$WORKDIR\" \\\n    \"$CLAWCLAU_SHELL -l $WRAPPER_FILE $PROMPT_FILE $WORKDIR $TASK_LOG_FILE\"\n\n# Verify the session actually started\nsleep 1\nif ! tmux has-session -t \"$TMUX_SESSION\" 2>/dev/null; then\n    # Session died immediately — check if log was created for diagnostics\n    if [ -f \"$TASK_LOG_FILE\" ] && [ -s \"$TASK_LOG_FILE\" ]; then\n        echo \"ERROR: tmux session '$TMUX_SESSION' started but exited immediately.\"\n        echo \"  Last log output:\"\n        tail -5 \"$TASK_LOG_FILE\"\n    else\n        echo \"ERROR: tmux session '$TMUX_SESSION' failed to start (no TTY or claude not found).\"\n    fi\n    exit 1\nfi\n\n# --- Register task ---\nTIMESTAMP=$(date +%s000)\njq --arg id \"$TASK_ID\" \\\n   --arg session \"$TMUX_SESSION\" \\\n   --arg prompt \"$PROMPT\" \\\n   --arg workdir \"$WORKDIR\" \\\n   --arg log \"$LOG_DIR/${TASK_ID}.log\" \\\n   --arg ts \"$TIMESTAMP\" \\\n   --arg timeout \"$TIMEOUT\" \\\n   '. += [{\"id\": $id, \"tmuxSession\": $session, \"prompt\": $prompt, \"workdir\": $workdir, \"log\": $log, \"startedAt\": ($ts|tonumber), \"status\": \"running\", \"timeout\": ($timeout|tonumber)}]' \\\n   \"$TASK_REGISTRY\" > \"$TASK_REGISTRY.tmp\" && mv \"$TASK_REGISTRY.tmp\" \"$TASK_REGISTRY\"\n\n# --- Background monitor: auto-notify when task finishes ---\n(\n    # Source profile so openclaw is in PATH\n    export PATH=\"/opt/homebrew/bin:/usr/local/bin:$HOME/.openclaw/bin:$PATH\"\n    while tmux has-session -t \"$TMUX_SESSION\" 2>/dev/null; do\n        sleep 10\n    done\n    # Session ended — wait for log flush\n    sleep 2\n    NOW_TS=$(date +%s000)\n    if [ -s \"$TASK_LOG_FILE\" ]; then\n        STATUS=\"done\"\n        EVENT_TEXT=\"Done: 任务 $TASK_ID 已完成\"\n    else\n        STATUS=\"failed\"\n        EVENT_TEXT=\"Failed: 任务 $TASK_ID 失败（空日志）\"\n    fi\n    # Update registry\n    jq --arg id \"$TASK_ID\" --arg ts \"$NOW_TS\" --arg status \"$STATUS\" \\\n        '(.[] | select(.id == $id)) |= . + {status: $status, completedAt: ($ts | tonumber)}' \\\n        \"$TASK_REGISTRY\" > \"$TASK_REGISTRY.tmp\" && mv \"$TASK_REGISTRY.tmp\" \"$TASK_REGISTRY\"\n    # Notify via openclaw\n    openclaw system event --text \"$EVENT_TEXT\" --mode now 2>/dev/null || true\n) &\ndisown\n\n# --- Background progress reporter (only active when --interval is set) ---\nif [ \"$PROGRESS_INTERVAL\" -gt 0 ]; then\n(\n    set +e  # Don't let transient errors kill the reporter\n    export PATH=\"/opt/homebrew/bin:/usr/local/bin:$HOME/.openclaw/bin:$PATH\"\n    START_TS=$(date +%s)\n    LAST_BYTES=0  # Dedup by byte offset, not line count\n\n    while tmux has-session -t \"$TMUX_SESSION\" 2>/dev/null; do\n        sleep \"$PROGRESS_INTERVAL\"\n\n        # Skip if log doesn't exist yet\n        [ -f \"$TASK_LOG_FILE\" ] || continue\n\n        # Dedup: skip if no new bytes since last report\n        CURRENT_BYTES=$(wc -c < \"$TASK_LOG_FILE\" 2>/dev/null | tr -d ' ' || echo 0)\n        [ \"$CURRENT_BYTES\" -le \"$LAST_BYTES\" ] && continue\n        LAST_BYTES=$CURRENT_BYTES\n\n        # Compute human-readable elapsed time\n        NOW_TS=$(date +%s)\n        ELAPSED=$(( NOW_TS - START_TS ))\n        if [ \"$ELAPSED\" -lt 60 ]; then\n            TIME_STR=\"${ELAPSED} 秒\"\n        else\n            TIME_STR=\"$(( ELAPSED / 60 )) 分钟\"\n        fi\n\n        # Extract readable text from stream-json log (NDJSON, one event per line).\n        # Priority: result event (full final output)\n        #         > last assistant event's text content (accumulated message)\n        #         > text_delta fragments joined (ongoing streaming)\n        _RAW_TEXT=$(tail -500 \"$TASK_LOG_FILE\" 2>/dev/null | jq -rs '\n          ([ .[] | select(.type == \"result\") | (.result // \"\") ] | last // \"\") as $result |\n          ([ .[] | select(.type == \"assistant\") |\n             ((.message.content // []) | map(select(.type == \"text\") | .text) | join(\"\"))\n          ] | last // \"\") as $assistant |\n          ([ .[] |\n             select(.type == \"stream_event\") |\n             select(.event.type == \"content_block_delta\") |\n             select(.event.delta.type == \"text_delta\") |\n             .event.delta.text\n          ] | join(\"\")) as $delta |\n          if $result != \"\" then $result\n          elif $assistant != \"\" then $assistant\n          elif $delta != \"\" then $delta\n          else \"\"\n          end\n        ' 2>/dev/null)\n        # Truncate to last 200 chars to keep notifications readable\n        LOG_SNIPPET=\"${_RAW_TEXT: -200}\"\n\n        _EVENT_TEXT=\"[进度] 任务 $TASK_ID: 已运行 $TIME_STR\"$'\\n'\"最新输出：${LOG_SNIPPET}\"\n        openclaw system event \\\n            --text \"$_EVENT_TEXT\" \\\n            --mode now 2>/dev/null || true\n    done\n) &\ndisown\nfi\n\necho \"OK: spawned '$TASK_ID' in tmux session '$TMUX_SESSION'\"\necho \"  Prompt: $PROMPT\"\necho \"  Workdir: $WORKDIR\"\necho \"  Log: $LOG_DIR/${TASK_ID}.log\"\necho \"  Timeout: ${TIMEOUT}s\"\necho \"  Monitor: background (auto-notify on completion)\"\nif [ \"$PROGRESS_INTERVAL\" -gt 0 ]; then\n    echo \"  Progress: every ${PROGRESS_INTERVAL}s (--interval)\"\nfi\n","numLines":239,"startLine":1,"totalLines":239}}}
