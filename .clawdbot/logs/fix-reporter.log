{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01DcPbcxy4Vc2yKUet2hrWp8","type":"tool_result","content":"     1→#!/bin/bash\n     2→# claude-spawn.sh — Spawn a Claude Code task in a tmux session\n     3→# Usage: claude-spawn.sh <task-id> \"<prompt>\" [workdir] [timeout-seconds] [--interval <seconds>]\n     4→\n     5→set -euo pipefail\n     6→\n     7→# --- Dependency check ---\n     8→for cmd in tmux jq; do\n     9→    command -v \"$cmd\" >/dev/null 2>&1 || { echo \"ERROR: '$cmd' is required but not installed.\"; exit 1; }\n    10→done\n    11→\n    12→# --- Configurable paths ---\n    13→CLAWCLAU_HOME=\"${CLAWCLAU_HOME:-$HOME/.openclaw/workspace/.clawdbot}\"\n    14→TASK_REGISTRY=\"$CLAWCLAU_HOME/active-tasks.json\"\n    15→LOG_DIR=\"$CLAWCLAU_HOME/logs\"\n    16→CLAWCLAU_SHELL=\"${CLAWCLAU_SHELL:-bash}\"\n    17→\n    18→# --- Pre-parse named flags (--interval) before positional args ---\n    19→PROGRESS_INTERVAL=0\n    20→REMAINING_ARGS=()\n    21→while [[ $# -gt 0 ]]; do\n    22→    case \"$1\" in\n    23→        --interval)\n    24→            if [[ -z \"${2:-}\" ]] || ! [[ \"${2}\" =~ ^[0-9]+$ ]]; then\n    25→                echo \"ERROR: --interval requires a positive integer (seconds). Got: '${2:-}'\"\n    26→                exit 1\n    27→            fi\n    28→            PROGRESS_INTERVAL=\"$2\"\n    29→            shift 2\n    30→            ;;\n    31→        *)\n    32→            REMAINING_ARGS+=(\"$1\")\n    33→            shift\n    34→            ;;\n    35→    esac\n    36→done\n    37→set -- \"${REMAINING_ARGS[@]+\"${REMAINING_ARGS[@]}\"}\"\n    38→\n    39→# --- Argument validation ---\n    40→if [ $# -lt 2 ]; then\n    41→    echo \"Usage: claude-spawn.sh <task-id> \\\"<prompt>\\\" [workdir] [timeout-seconds] [--interval <seconds>]\"\n    42→    exit 1\n    43→fi\n    44→\n    45→TASK_ID=\"$1\"\n    46→PROMPT=\"$2\"\n    47→WORKDIR=\"${3:-$(pwd)}\"\n    48→TIMEOUT=\"${4:-600}\"\n    49→\n    50→# --- Input sanitization (task-id: alphanumeric, dash, underscore only) ---\n    51→if ! echo \"$TASK_ID\" | grep -qE '^[a-zA-Z0-9_-]+$'; then\n    52→    echo \"ERROR: task-id must be alphanumeric (a-z, A-Z, 0-9, -, _). Got: '$TASK_ID'\"\n    53→    exit 1\n    54→fi\n    55→\n    56→TMUX_SESSION=\"claude-${TASK_ID}\"\n    57→\n    58→# --- Init directories and registry ---\n    59→mkdir -p \"$LOG_DIR\"\n    60→[ -f \"$TASK_REGISTRY\" ] || echo '[]' > \"$TASK_REGISTRY\"\n    61→\n    62→# --- Check for existing session ---\n    63→if tmux has-session -t \"$TMUX_SESSION\" 2>/dev/null; then\n    64→    echo \"ERROR: tmux session '$TMUX_SESSION' already exists\"\n    65→    exit 1\n    66→fi\n    67→\n    68→# --- Write prompt to temp file and generate wrapper script ---\n    69→# This avoids the nightmare of nesting quotes through tmux → shell → claude.\n    70→PROMPT_FILE=\"$CLAWCLAU_HOME/prompts/${TASK_ID}.txt\"\n    71→WRAPPER_FILE=\"$CLAWCLAU_HOME/prompts/${TASK_ID}.sh\"\n    72→TASK_LOG_FILE=\"$LOG_DIR/${TASK_ID}.log\"\n    73→mkdir -p \"$CLAWCLAU_HOME/prompts\" \"$LOG_DIR\"\n    74→printf '%s' \"$PROMPT\" > \"$PROMPT_FILE\"\n    75→\n    76→# The wrapper runs claude with --output-format stream-json, which makes claude\n    77→# explicitly flush each JSON event line to stdout immediately — even in pipe mode.\n    78→# This means tee receives data in real time, and the log file grows as the API\n    79→# streams tokens, not all at once when the task finishes.\n    80→#\n    81→# WHY NOT plain `tee`: claude -p in default text mode buffers ALL output until\n    82→# the API call completes, then writes everything at once. Log stays at 0 bytes.\n    83→#\n    84→# WHY NOT `script -q`: tested on macOS — script buffers its typescript file\n    85→# writes and only flushes when the child process exits. Same result as tee.\n    86→#\n    87→# WHY NOT `tmux pipe-pane`: the PTY gives claude line-buffering, but claude -p\n    88→# in text mode still accumulates the full API response before writing anything.\n    89→# The pipe-pane `cat` receives nothing until the API call finishes.\n    90→#\n    91→# WHY `--output-format stream-json`: claude explicitly flushes each JSON event\n    92→# to stdout immediately as it streams from the API. The stdio buffer never\n    93→# accumulates; every token is written to the log file within milliseconds.\n    94→# Tested: log grows from 0→1153 bytes at t=4s while the session is still alive.\n    95→cat > \"$WRAPPER_FILE\" << 'WRAPPER_EOF'\n    96→#!/bin/bash\n    97→# $1 = PROMPT_FILE, $2 = WORKDIR, $3 = LOG_FILE\n    98→cd \"$2\"\n    99→CLAWCLAU_PROMPT_FILE=\"$1\"\n   100→export CLAWCLAU_PROMPT_FILE\n   101→# --output-format stream-json: each API token/event is flushed to stdout\n   102→# immediately, making tee write to the log file in real time.\n   103→# --include-partial-messages: emit each text token as a separate event.\n   104→# --verbose: required when --output-format=stream-json is used with --print.\n   105→claude -p --dangerously-skip-permissions \\\n   106→    --verbose --output-format stream-json --include-partial-messages \\\n   107→    \"$(cat \"$CLAWCLAU_PROMPT_FILE\")\" 2>&1 | tee \"$3\"\n   108→WRAPPER_EOF\n   109→chmod +x \"$WRAPPER_FILE\"\n   110→\n   111→# --- Launch Claude Code in tmux ---\n   112→# Uses login shell to ensure PATH and env vars are loaded.\n   113→# --dangerously-skip-permissions bypasses interactive approval — see SECURITY.md.\n   114→tmux new-session -d -s \"$TMUX_SESSION\" -c \"$WORKDIR\" \\\n   115→    \"$CLAWCLAU_SHELL -l $WRAPPER_FILE $PROMPT_FILE $WORKDIR $TASK_LOG_FILE\"\n   116→\n   117→# Verify the session actually started\n   118→sleep 1\n   119→if ! tmux has-session -t \"$TMUX_SESSION\" 2>/dev/null; then\n   120→    # Session died immediately — check if log was created for diagnostics\n   121→    if [ -f \"$TASK_LOG_FILE\" ] && [ -s \"$TASK_LOG_FILE\" ]; then\n   122→        echo \"ERROR: tmux session '$TMUX_SESSION' started but exited immediately.\"\n   123→        echo \"  Last log output:\"\n   124→        tail -5 \"$TASK_LOG_FILE\"\n   125→    else\n   126→        echo \"ERROR: tmux session '$TMUX_SESSION' failed to start (no TTY or claude not found).\"\n   127→    fi\n   128→    exit 1\n   129→fi\n   130→\n   131→# --- Register task ---\n   132→TIMESTAMP=$(date +%s000)\n   133→jq --arg id \"$TASK_ID\" \\\n   134→   --arg session \"$TMUX_SESSION\" \\\n   135→   --arg prompt \"$PROMPT\" \\\n   136→   --arg workdir \"$WORKDIR\" \\\n   137→   --arg log \"$LOG_DIR/${TASK_ID}.log\" \\\n   138→   --arg ts \"$TIMESTAMP\" \\\n   139→   --arg timeout \"$TIMEOUT\" \\\n   140→   '. += [{\"id\": $id, \"tmuxSession\": $session, \"prompt\": $prompt, \"workdir\": $workdir, \"log\": $log, \"startedAt\": ($ts|tonumber), \"status\": \"running\", \"timeout\": ($timeout|tonumber)}]' \\\n   141→   \"$TASK_REGISTRY\" > \"$TASK_REGISTRY.tmp\" && mv \"$TASK_REGISTRY.tmp\" \"$TASK_REGISTRY\"\n   142→\n   143→# --- Background monitor: auto-notify when task finishes ---\n   144→(\n   145→    # Source profile so openclaw is in PATH\n   146→    export PATH=\"/opt/homebrew/bin:/usr/local/bin:$HOME/.openclaw/bin:$PATH\"\n   147→    while tmux has-session -t \"$TMUX_SESSION\" 2>/dev/null; do\n   148→        sleep 10\n   149→    done\n   150→    # Session ended — wait for log flush\n   151→    sleep 2\n   152→    NOW_TS=$(date +%s000)\n   153→    if [ -s \"$TASK_LOG_FILE\" ]; then\n   154→        STATUS=\"done\"\n   155→        EVENT_TEXT=\"Done: 任务 $TASK_ID 已完成\"\n   156→    else\n   157→        STATUS=\"failed\"\n   158→        EVENT_TEXT=\"Failed: 任务 $TASK_ID 失败（空日志）\"\n   159→    fi\n   160→    # Update registry\n   161→    jq --arg id \"$TASK_ID\" --arg ts \"$NOW_TS\" --arg status \"$STATUS\" \\\n   162→        '(.[] | select(.id == $id)) |= . + {status: $status, completedAt: ($ts | tonumber)}' \\\n   163→        \"$TASK_REGISTRY\" > \"$TASK_REGISTRY.tmp\" && mv \"$TASK_REGISTRY.tmp\" \"$TASK_REGISTRY\"\n   164→    # Notify via openclaw\n   165→    openclaw system event --text \"$EVENT_TEXT\" --mode now 2>/dev/null || true\n   166→) &\n   167→disown\n   168→\n   169→# --- Background progress reporter (only active when --interval is set) ---\n   170→if [ \"$PROGRESS_INTERVAL\" -gt 0 ]; then\n   171→(\n   172→    set +e  # Don't let transient errors kill the reporter\n   173→    export PATH=\"/opt/homebrew/bin:/usr/local/bin:$HOME/.openclaw/bin:$PATH\"\n   174→    START_TS=$(date +%s)\n   175→    LAST_LOG_LINES=0\n   176→\n   177→    while tmux has-session -t \"$TMUX_SESSION\" 2>/dev/null; do\n   178→        sleep \"$PROGRESS_INTERVAL\"\n   179→\n   180→        # Skip if log doesn't exist yet\n   181→        [ -f \"$TASK_LOG_FILE\" ] || continue\n   182→\n   183→        CURRENT_LINES=$(wc -l < \"$TASK_LOG_FILE\" 2>/dev/null || echo 0)\n   184→        # Skip if no new content since last report\n   185→        [ \"$CURRENT_LINES\" -le \"$LAST_LOG_LINES\" ] && continue\n   186→        LAST_LOG_LINES=$CURRENT_LINES\n   187→\n   188→        # Compute human-readable elapsed time\n   189→        NOW_TS=$(date +%s)\n   190→        ELAPSED=$(( NOW_TS - START_TS ))\n   191→        if [ \"$ELAPSED\" -lt 60 ]; then\n   192→            TIME_STR=\"${ELAPSED} 秒\"\n   193→        else\n   194→            TIME_STR=\"$(( ELAPSED / 60 )) 分钟\"\n   195→        fi\n   196→\n   197→        # Extract recent text from stream-json log (one JSON event per line).\n   198→        # Select content_block_delta events and extract the text field.\n   199→        LOG_SNIPPET=$(tail -100 \"$TASK_LOG_FILE\" 2>/dev/null \\\n   200→            | jq -r 'select(.type==\"stream_event\" and .event.type==\"content_block_delta\") | .event.delta.text // empty' 2>/dev/null \\\n   201→            | grep -v '^$' \\\n   202→            | tail -6 \\\n   203→            | tr '\\n' ' ')\n   204→\n   205→        openclaw system event \\\n   206→            --text \"[进度] 任务 $TASK_ID: 已运行 $TIME_STR，日志最新输出：$LOG_SNIPPET\" \\\n   207→            --mode now 2>/dev/null || true\n   208→    done\n   209→) &\n   210→disown\n   211→fi\n   212→\n   213→echo \"OK: spawned '$TASK_ID' in tmux session '$TMUX_SESSION'\"\n   214→echo \"  Prompt: $PROMPT\"\n   215→echo \"  Workdir: $WORKDIR\"\n   216→echo \"  Log: $LOG_DIR/${TASK_ID}.log\"\n   217→echo \"  Timeout: ${TIMEOUT}s\"\n   218→echo \"  Monitor: background (auto-notify on completion)\"\n   219→if [ \"$PROGRESS_INTERVAL\" -gt 0 ]; then\n   220→    echo \"  Progress: every ${PROGRESS_INTERVAL}s (--interval)\"\n   221→fi\n   222→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"11eb47d5-9abd-4672-b0fd-3531b749ab95","uuid":"9ef164a9-2a39-4b31-90b1-ac0815a34cf1","timestamp":"2026-03-19T08:21:51.672Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/yjj/.openclaw/workspace/skills/clawclau/scripts/claude-spawn.sh","content":"#!/bin/bash\n# claude-spawn.sh — Spawn a Claude Code task in a tmux session\n# Usage: claude-spawn.sh <task-id> \"<prompt>\" [workdir] [timeout-seconds] [--interval <seconds>]\n\nset -euo pipefail\n\n# --- Dependency check ---\nfor cmd in tmux jq; do\n    command -v \"$cmd\" >/dev/null 2>&1 || { echo \"ERROR: '$cmd' is required but not installed.\"; exit 1; }\ndone\n\n# --- Configurable paths ---\nCLAWCLAU_HOME=\"${CLAWCLAU_HOME:-$HOME/.openclaw/workspace/.clawdbot}\"\nTASK_REGISTRY=\"$CLAWCLAU_HOME/active-tasks.json\"\nLOG_DIR=\"$CLAWCLAU_HOME/logs\"\nCLAWCLAU_SHELL=\"${CLAWCLAU_SHELL:-bash}\"\n\n# --- Pre-parse named flags (--interval) before positional args ---\nPROGRESS_INTERVAL=0\nREMAINING_ARGS=()\nwhile [[ $# -gt 0 ]]; do\n    case \"$1\" in\n        --interval)\n            if [[ -z \"${2:-}\" ]] || ! [[ \"${2}\" =~ ^[0-9]+$ ]]; then\n                echo \"ERROR: --interval requires a positive integer (seconds). Got: '${2:-}'\"\n                exit 1\n            fi\n            PROGRESS_INTERVAL=\"$2\"\n            shift 2\n            ;;\n        *)\n            REMAINING_ARGS+=(\"$1\")\n            shift\n            ;;\n    esac\ndone\nset -- \"${REMAINING_ARGS[@]+\"${REMAINING_ARGS[@]}\"}\"\n\n# --- Argument validation ---\nif [ $# -lt 2 ]; then\n    echo \"Usage: claude-spawn.sh <task-id> \\\"<prompt>\\\" [workdir] [timeout-seconds] [--interval <seconds>]\"\n    exit 1\nfi\n\nTASK_ID=\"$1\"\nPROMPT=\"$2\"\nWORKDIR=\"${3:-$(pwd)}\"\nTIMEOUT=\"${4:-600}\"\n\n# --- Input sanitization (task-id: alphanumeric, dash, underscore only) ---\nif ! echo \"$TASK_ID\" | grep -qE '^[a-zA-Z0-9_-]+$'; then\n    echo \"ERROR: task-id must be alphanumeric (a-z, A-Z, 0-9, -, _). Got: '$TASK_ID'\"\n    exit 1\nfi\n\nTMUX_SESSION=\"claude-${TASK_ID}\"\n\n# --- Init directories and registry ---\nmkdir -p \"$LOG_DIR\"\n[ -f \"$TASK_REGISTRY\" ] || echo '[]' > \"$TASK_REGISTRY\"\n\n# --- Check for existing session ---\nif tmux has-session -t \"$TMUX_SESSION\" 2>/dev/null; then\n    echo \"ERROR: tmux session '$TMUX_SESSION' already exists\"\n    exit 1\nfi\n\n# --- Write prompt to temp file and generate wrapper script ---\n# This avoids the nightmare of nesting quotes through tmux → shell → claude.\nPROMPT_FILE=\"$CLAWCLAU_HOME/prompts/${TASK_ID}.txt\"\nWRAPPER_FILE=\"$CLAWCLAU_HOME/prompts/${TASK_ID}.sh\"\nTASK_LOG_FILE=\"$LOG_DIR/${TASK_ID}.log\"\nmkdir -p \"$CLAWCLAU_HOME/prompts\" \"$LOG_DIR\"\nprintf '%s' \"$PROMPT\" > \"$PROMPT_FILE\"\n\n# The wrapper runs claude with --output-format stream-json, which makes claude\n# explicitly flush each JSON event line to stdout immediately — even in pipe mode.\n# This means tee receives data in real time, and the log file grows as the API\n# streams tokens, not all at once when the task finishes.\n#\n# WHY NOT plain `tee`: claude -p in default text mode buffers ALL output until\n# the API call completes, then writes everything at once. Log stays at 0 bytes.\n#\n# WHY NOT `script -q`: tested on macOS — script buffers its typescript file\n# writes and only flushes when the child process exits. Same result as tee.\n#\n# WHY NOT `tmux pipe-pane`: the PTY gives claude line-buffering, but claude -p\n# in text mode still accumulates the full API response before writing anything.\n# The pipe-pane `cat` receives nothing until the API call finishes.\n#\n# WHY `--output-format stream-json`: claude explicitly flushes each JSON event\n# to stdout immediately as it streams from the API. The stdio buffer never\n# accumulates; every token is written to the log file within milliseconds.\n# Tested: log grows from 0→1153 bytes at t=4s while the session is still alive.\ncat > \"$WRAPPER_FILE\" << 'WRAPPER_EOF'\n#!/bin/bash\n# $1 = PROMPT_FILE, $2 = WORKDIR, $3 = LOG_FILE\ncd \"$2\"\nCLAWCLAU_PROMPT_FILE=\"$1\"\nexport CLAWCLAU_PROMPT_FILE\n# --output-format stream-json: each API token/event is flushed to stdout\n# immediately, making tee write to the log file in real time.\n# --include-partial-messages: emit each text token as a separate event.\n# --verbose: required when --output-format=stream-json is used with --print.\nclaude -p --dangerously-skip-permissions \\\n    --verbose --output-format stream-json --include-partial-messages \\\n    \"$(cat \"$CLAWCLAU_PROMPT_FILE\")\" 2>&1 | tee \"$3\"\nWRAPPER_EOF\nchmod +x \"$WRAPPER_FILE\"\n\n# --- Launch Claude Code in tmux ---\n# Uses login shell to ensure PATH and env vars are loaded.\n# --dangerously-skip-permissions bypasses interactive approval — see SECURITY.md.\ntmux new-session -d -s \"$TMUX_SESSION\" -c \"$WORKDIR\" \\\n    \"$CLAWCLAU_SHELL -l $WRAPPER_FILE $PROMPT_FILE $WORKDIR $TASK_LOG_FILE\"\n\n# Verify the session actually started\nsleep 1\nif ! tmux has-session -t \"$TMUX_SESSION\" 2>/dev/null; then\n    # Session died immediately — check if log was created for diagnostics\n    if [ -f \"$TASK_LOG_FILE\" ] && [ -s \"$TASK_LOG_FILE\" ]; then\n        echo \"ERROR: tmux session '$TMUX_SESSION' started but exited immediately.\"\n        echo \"  Last log output:\"\n        tail -5 \"$TASK_LOG_FILE\"\n    else\n        echo \"ERROR: tmux session '$TMUX_SESSION' failed to start (no TTY or claude not found).\"\n    fi\n    exit 1\nfi\n\n# --- Register task ---\nTIMESTAMP=$(date +%s000)\njq --arg id \"$TASK_ID\" \\\n   --arg session \"$TMUX_SESSION\" \\\n   --arg prompt \"$PROMPT\" \\\n   --arg workdir \"$WORKDIR\" \\\n   --arg log \"$LOG_DIR/${TASK_ID}.log\" \\\n   --arg ts \"$TIMESTAMP\" \\\n   --arg timeout \"$TIMEOUT\" \\\n   '. += [{\"id\": $id, \"tmuxSession\": $session, \"prompt\": $prompt, \"workdir\": $workdir, \"log\": $log, \"startedAt\": ($ts|tonumber), \"status\": \"running\", \"timeout\": ($timeout|tonumber)}]' \\\n   \"$TASK_REGISTRY\" > \"$TASK_REGISTRY.tmp\" && mv \"$TASK_REGISTRY.tmp\" \"$TASK_REGISTRY\"\n\n# --- Background monitor: auto-notify when task finishes ---\n(\n    # Source profile so openclaw is in PATH\n    export PATH=\"/opt/homebrew/bin:/usr/local/bin:$HOME/.openclaw/bin:$PATH\"\n    while tmux has-session -t \"$TMUX_SESSION\" 2>/dev/null; do\n        sleep 10\n    done\n    # Session ended — wait for log flush\n    sleep 2\n    NOW_TS=$(date +%s000)\n    if [ -s \"$TASK_LOG_FILE\" ]; then\n        STATUS=\"done\"\n        EVENT_TEXT=\"Done: 任务 $TASK_ID 已完成\"\n    else\n        STATUS=\"failed\"\n        EVENT_TEXT=\"Failed: 任务 $TASK_ID 失败（空日志）\"\n    fi\n    # Update registry\n    jq --arg id \"$TASK_ID\" --arg ts \"$NOW_TS\" --arg status \"$STATUS\" \\\n        '(.[] | select(.id == $id)) |= . + {status: $status, completedAt: ($ts | tonumber)}' \\\n        \"$TASK_REGISTRY\" > \"$TASK_REGISTRY.tmp\" && mv \"$TASK_REGISTRY.tmp\" \"$TASK_REGISTRY\"\n    # Notify via openclaw\n    openclaw system event --text \"$EVENT_TEXT\" --mode now 2>/dev/null || true\n) &\ndisown\n\n# --- Background progress reporter (only active when --interval is set) ---\nif [ \"$PROGRESS_INTERVAL\" -gt 0 ]; then\n(\n    set +e  # Don't let transient errors kill the reporter\n    export PATH=\"/opt/homebrew/bin:/usr/local/bin:$HOME/.openclaw/bin:$PATH\"\n    START_TS=$(date +%s)\n    LAST_LOG_LINES=0\n\n    while tmux has-session -t \"$TMUX_SESSION\" 2>/dev/null; do\n        sleep \"$PROGRESS_INTERVAL\"\n\n        # Skip if log doesn't exist yet\n        [ -f \"$TASK_LOG_FILE\" ] || continue\n\n        CURRENT_LINES=$(wc -l < \"$TASK_LOG_FILE\" 2>/dev/null || echo 0)\n        # Skip if no new content since last report\n        [ \"$CURRENT_LINES\" -le \"$LAST_LOG_LINES\" ] && continue\n        LAST_LOG_LINES=$CURRENT_LINES\n\n        # Compute human-readable elapsed time\n        NOW_TS=$(date +%s)\n        ELAPSED=$(( NOW_TS - START_TS ))\n        if [ \"$ELAPSED\" -lt 60 ]; then\n            TIME_STR=\"${ELAPSED} 秒\"\n        else\n            TIME_STR=\"$(( ELAPSED / 60 )) 分钟\"\n        fi\n\n        # Extract recent text from stream-json log (one JSON event per line).\n        # Select content_block_delta events and extract the text field.\n        LOG_SNIPPET=$(tail -100 \"$TASK_LOG_FILE\" 2>/dev/null \\\n            | jq -r 'select(.type==\"stream_event\" and .event.type==\"content_block_delta\") | .event.delta.text // empty' 2>/dev/null \\\n            | grep -v '^$' \\\n            | tail -6 \\\n            | tr '\\n' ' ')\n\n        openclaw system event \\\n            --text \"[进度] 任务 $TASK_ID: 已运行 $TIME_STR，日志最新输出：$LOG_SNIPPET\" \\\n            --mode now 2>/dev/null || true\n    done\n) &\ndisown\nfi\n\necho \"OK: spawned '$TASK_ID' in tmux session '$TMUX_SESSION'\"\necho \"  Prompt: $PROMPT\"\necho \"  Workdir: $WORKDIR\"\necho \"  Log: $LOG_DIR/${TASK_ID}.log\"\necho \"  Timeout: ${TIMEOUT}s\"\necho \"  Monitor: background (auto-notify on completion)\"\nif [ \"$PROGRESS_INTERVAL\" -gt 0 ]; then\n    echo \"  Progress: every ${PROGRESS_INTERVAL}s (--interval)\"\nfi\n","numLines":222,"startLine":1,"totalLines":222}}}
